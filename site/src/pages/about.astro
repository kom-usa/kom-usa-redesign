---
import { Image } from "astro:assets";
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import BaseLayout from "../layouts/BaseLayout.astro";
import { business } from "../data/business";
import crewAtWork from "../assets/images/projects/crew-at-work.jpeg";
import interiorRenovation from "../assets/images/interior-renovation.jpg";
---

<BaseLayout title="About KOM USA | Metro Detroit Maintenance & Construction" description="KOM USA is a local Metro Detroit maintenance and construction team serving homeowners, properties, and contractors.">
  <section class="bg-kom-warm-white">
    <div class="mx-auto grid max-w-7xl items-center gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-20">
      <div><p class="text-kom-field font-extrabold">About KOM USA</p><h1 class="text-kom-charcoal-deep mt-3 text-4xl font-black tracking-[-0.03em] text-balance sm:text-5xl lg:text-6xl">One local team, organized around the work</h1><p class="mt-5 max-w-2xl text-lg leading-relaxed text-kom-charcoal/75">KOM USA supports Metro Detroit homeowners and contractors with two clear service lines: Maintenance for repairs and property upkeep, and Construction for remodeling, building, and larger projects.</p></div>
      <Image src={crewAtWork} alt="KOM USA crew members at work on a Metro Detroit tile job" class="aspect-[4/3] w-full object-cover" style="border-radius: 14px;" widths={[560, 800, 1100]} sizes="(min-width: 1024px) 43vw, 100vw" loading="eager" />
    </div>
  </section>
  <section class="section-pad bg-white"><div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8"><div><h2 class="text-kom-charcoal-deep text-3xl font-black sm:text-4xl">Built for straightforward decisions</h2><p class="mt-4 leading-relaxed text-kom-charcoal/75">Customers should not need to decode a long service menu or send the same information twice. The website routes every request through the right phone number and one adaptive form while keeping scope, timing, and pricing expectations honest.</p><ul class="mt-6 space-y-3 font-bold text-kom-charcoal"><li>Maintenance: repairs, upkeep, systems, and handyman needs</li><li>Construction: remodeling, new work, materials, and larger scopes</li><li>Service requests accepted 24/7 without promising round-the-clock dispatch</li><li>Project-specific estimates after the details are reviewed</li></ul></div><Image src={interiorRenovation} alt="Completed interior renovation by KOM USA" class="aspect-[4/3] w-full object-cover" style="border-radius: 14px;" widths={[560, 800]} sizes="(min-width: 1024px) 45vw, 100vw" loading="lazy" /></div></section>
  <section class="section-pad bg-kom-charcoal-deep text-white"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><h2 class="max-w-3xl text-3xl font-black text-balance sm:text-4xl">Serving Metro Detroit properties and projects</h2><p class="mt-4 max-w-3xl leading-relaxed text-white/70">KOM USA works throughout Metro Detroit. Include the address or ZIP, project type, and available details so the team can confirm travel, timing, and the right next step.</p><a href="/request-service/" class="bg-kom-field mt-6 inline-flex h-12 items-center rounded-md px-6 font-extrabold">Request Service or an Estimate<ArrowRight class="ml-2 size-4" aria-hidden="true" /></a><p class="mt-5 text-sm text-white/60">Email: {business.email}</p></div></section>
</BaseLayout>
