---
import { Image } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";
import CircleCheck from "@tabler/icons/outline/circle-check.svg";

import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/starwind/button/Button.astro";
import Roofline from "../components/common/Roofline.astro";
import { business, serviceAreaCounties } from "../data/business";
import homeExterior from "../assets/images/home-exterior.jpg";
import workerElectrical from "../assets/images/worker-electrical.jpg";

const helps = [
  {
    who: "Homeowners",
    how: "Repairs, remodels, and the maintenance list that never quite gets done.",
  },
  {
    who: "Landlords",
    how: "Turnovers, lock changes, and repairs between tenants — without chasing five vendors.",
  },
  {
    who: "Property managers",
    how: "A reliable maintenance arm that communicates clearly and shows up when scheduled.",
  },
  {
    who: "Investors",
    how: "Getting a property rent-ready or market-ready with one crew and one invoice.",
  },
];

const different = [
  "One crew across multiple trades — construction, maintenance, locksmith, and chimney work",
  "Clear communication — you know what's happening, when, and what it costs",
  "Practical scheduling — including tenant coordination and vacant-property access",
  "Local service — based in Metro Detroit, working where you are",
];
---

<BaseLayout
  title="About KOM USA | One Local Crew for Metro Detroit Properties"
  description="KOM USA is a Metro Detroit construction, maintenance, locksmith, and chimney service company serving homeowners, landlords, property managers, and investors across Wayne, Oakland, and Macomb counties."
>
  <section class="border-b bg-white">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-12 sm:px-6 md:py-16 lg:grid-cols-[1.4fr_1fr]">
      <div class="reveal">
        <p class="text-kom-field text-xs font-bold tracking-[0.18em] uppercase">About KOM USA</p>
        <h1 class="font-serif text-kom-ink mt-2 text-3xl font-bold text-balance sm:text-4xl lg:text-[2.6rem] lg:leading-[1.15]">
          A hometown crew for the work your property actually needs.
        </h1>
        <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
          KOM USA is a Metro Detroit service company covering construction and remodeling,
          property maintenance, locksmith work, chimney care, and rental turnovers — the trades
          most homes and rentals need, handled by one local team.
        </p>
      </div>
      <figure class="reveal" style="--rd: 100ms">
        <Image
          src={workerElectrical}
          alt="Technician in a hard hat servicing an electrical box"
          class="w-full rounded-xl object-cover shadow-card"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 35vw, 100vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <section class="section-pad">
    <div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="reveal">
        <h2 class="font-serif text-kom-ink text-2xl font-bold sm:text-3xl">Where we work</h2>
        <p class="text-muted-foreground mt-3 leading-relaxed">
          We serve {business.serviceArea} — {serviceAreaCounties.join(", ").replace(/, ([^,]*)$/, ", and $1")}.
          From Detroit neighborhoods to the suburbs, if you're in the metro area, you're in our
          service area. Not sure? <a href={business.phoneHref} class="text-kom-field font-bold hover:underline">Call</a> or <a href={business.smsHref} class="text-kom-field font-bold hover:underline">text us</a> and we'll tell you right away.
        </p>

        <h2 class="font-serif text-kom-ink mt-10 text-2xl font-bold sm:text-3xl">Why we exist</h2>
        <p class="text-muted-foreground mt-3 leading-relaxed">
          Most property work gets split across a contractor, a handyman, a locksmith, a chimney
          company, and a lawn crew — five phone numbers, five schedules, five invoices. We built
          KOM USA so one call covers it. You get one team that already knows your property, your
          locks, and how you like things done.
        </p>

        <h2 class="font-serif text-kom-ink mt-10 text-2xl font-bold sm:text-3xl">
          What makes us different
        </h2>
        <ul class="mt-4 space-y-2.5">
          {
            different.map((item) => (
              <li class="text-kom-charcoal/90 flex items-start gap-2.5 text-sm leading-relaxed font-medium">
                <CircleCheck class="text-kom-field mt-0.5 size-4.5 shrink-0" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="reveal" style="--rd: 100ms">
        <h2 class="font-serif text-kom-ink text-2xl font-bold sm:text-3xl">Who we help</h2>
        <ul class="mt-4 grid gap-4">
          {
            helps.map((item) => (
              <li class="border-border rounded-xl border bg-white p-5 shadow-card">
                <h3 class="text-kom-ink text-base font-bold">{item.who}</h3>
                <p class="text-muted-foreground mt-1 text-sm leading-relaxed">{item.how}</p>
              </li>
            ))
          }
        </ul>
        <figure class="mt-6">
          <Image
            src={homeExterior}
            alt="Well-kept two-story home with a wraparound porch"
            class="w-full rounded-xl object-cover shadow-card"
            widths={[480, 800]}
            sizes="(min-width: 1024px) 45vw, 100vw"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>

  <section class="bg-kom-field-deep">
    <div class="mx-auto flex max-w-6xl flex-col items-center px-4 py-14 text-center sm:px-6">
      <Roofline class="text-kom-tan" />
      <h2 class="font-serif mt-4 max-w-2xl text-2xl font-bold text-balance text-white sm:text-3xl">
        Have a project or a portfolio that needs a crew?
      </h2>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <Button href="/contact" variant="primary" size="lg" class="font-bold">
          Request service
        </Button>
        <Button
          href={business.phoneHref}
          size="lg"
          class="border border-white/30 bg-transparent font-bold text-white hover:bg-white/10 focus-visible:ring-white/40"
        >
          <Phone aria-hidden="true" />
          Call {business.phone}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
