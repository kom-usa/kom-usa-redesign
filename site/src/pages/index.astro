---
import { Image } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import Camera from "@tabler/icons/outline/camera.svg";
import Clock from "@tabler/icons/outline/clock.svg";
import ClipboardCheck from "@tabler/icons/outline/clipboard-check.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import StarFilled from "@tabler/icons/filled/star.svg";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/common/Icon.astro";
import Gallery from "../components/sections/Gallery.astro";
import GoogleReviews from "../components/sections/GoogleReviews.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import ServiceArea from "../components/sections/ServiceArea.astro";
import Faq from "../components/sections/Faq.astro";
import AdaptiveRequestForm from "../components/sections/AdaptiveRequestForm.astro";
import { business, googleReviews } from "../data/business";
import { maintenanceServices, servicePath } from "../data/service-catalog";
import { getReviewStats } from "../lib/google-reviews";
import homeExterior from "../assets/images/home-exterior.jpg";
import workerPortrait from "../assets/images/worker-portrait.jpg";
import interiorRenovation from "../assets/images/interior-renovation.jpg";

const reviews = await getReviewStats();
const popularServiceSpecs = [
  { slug: "handyman-services", icon: "tool" },
  { slug: "drain-cleaning", icon: "droplet" },
  { slug: "locksmith", icon: "lock" },
  { slug: "water-heaters", icon: "flame" },
  { slug: "air-duct-cleaning", icon: "wind" },
  { slug: "drywall-repair", icon: "brush" },
];
const popularMaintenance = popularServiceSpecs.map(({ slug, icon }) => ({
  service: maintenanceServices.find((item) => item.slug === slug)!,
  icon,
}));
---

<BaseLayout
  title="Home Maintenance & Construction in Metro Detroit | KOM USA"
  description="KOM USA provides home maintenance, handyman, remodeling, construction, and project support across Metro Detroit for homeowners and contractors."
  includeBusinessGraph
>
  <section class="overflow-hidden bg-white">
    <div class="mx-auto grid max-w-7xl items-center gap-10 px-4 py-12 sm:px-6 sm:py-16 lg:grid-cols-2 lg:gap-14 lg:px-8 lg:py-20">
      <div class="order-2 lg:order-1">
        <h1 class="max-w-3xl text-[clamp(2.7rem,5.5vw,4.65rem)] font-black leading-[0.98] tracking-[-0.045em] text-balance text-kom-ink">One Local Team for Home Maintenance and Construction</h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-kom-charcoal/72">From everyday repairs and handyman work to remodeling and new construction, KOM USA makes it easy to get your project started.</p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/request-service/?line=maintenance&intent=service" class="inline-flex min-h-12 items-center justify-center rounded-md bg-kom-field px-7 text-base font-extrabold text-white shadow-sm transition-colors hover:bg-kom-field-hover focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40">Request Service</a>
          <a href="/request-service/?line=construction&intent=estimate" class="inline-flex min-h-12 items-center justify-center rounded-md border-2 border-kom-field px-7 text-base font-extrabold text-kom-field transition-colors hover:bg-kom-field hover:text-white focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40">Request an Estimate</a>
        </div>
        <a href={googleReviews.url} target="_blank" rel="noopener" class="mt-7 inline-flex items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/35">
          <span class="flex text-kom-brass" aria-hidden="true">{Array.from({ length: 5 }).map(() => <StarFilled class="size-4" />)}</span>
          <span class="text-sm font-bold text-kom-charcoal"><span data-g-rating>{reviews.rating}</span> from <span data-g-count>{reviews.count}</span> Google reviews</span>
        </a>
        <div class="mt-7 grid gap-4 border-t border-kom-charcoal/10 pt-6 sm:grid-cols-2">
          <a href={business.maintenancePhoneHref} class="group flex items-center gap-3"><span class="flex size-10 items-center justify-center rounded-md bg-kom-sage-tint text-kom-field"><Phone class="size-5" aria-hidden="true" /></span><span><span class="block text-xs font-bold text-kom-charcoal/55">Maintenance</span><span class="font-black text-kom-field group-hover:underline">{business.maintenancePhone}</span></span></a>
          <a href={business.constructionPhoneHref} class="group flex items-center gap-3"><span class="flex size-10 items-center justify-center rounded-md bg-kom-sage-tint text-kom-field"><Phone class="size-5" aria-hidden="true" /></span><span><span class="block text-xs font-bold text-kom-charcoal/55">Construction</span><span class="font-black text-kom-field group-hover:underline">{business.constructionPhone}</span></span></a>
        </div>
      </div>
      <figure class="order-1 overflow-hidden rounded-2xl shadow-xl lg:order-2">
        <Image src={homeExterior} alt="Metro Detroit home served by KOM USA maintenance and construction teams" class="aspect-[4/3] w-full object-cover" widths={[640, 900, 1200]} sizes="(min-width: 1024px) 50vw, 100vw" loading="eager" />
      </figure>
    </div>
  </section>

  <section aria-label="Trust highlights" class="border-y border-kom-charcoal/10 bg-kom-warm-white">
    <ul class="mx-auto grid max-w-7xl gap-px px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      <li class="flex min-h-20 items-center gap-3 px-3 py-4 text-sm font-extrabold text-kom-ink"><MapPin class="size-5 shrink-0 text-kom-field" aria-hidden="true" />Locally owned in Metro Detroit</li>
      <li class="flex min-h-20 items-center gap-3 px-3 py-4 text-sm font-extrabold text-kom-ink"><Camera class="size-5 shrink-0 text-kom-field" aria-hidden="true" />Real project photography</li>
      <li class="flex min-h-20 items-center gap-3 px-3 py-4 text-sm font-extrabold text-kom-ink"><Clock class="size-5 shrink-0 text-kom-field" aria-hidden="true" />{business.availability}</li>
      <li class="flex min-h-20 items-center gap-3 px-3 py-4 text-sm font-extrabold text-kom-ink"><ClipboardCheck class="size-5 shrink-0 text-kom-field" aria-hidden="true" />One clear request form</li>
    </ul>
  </section>

  <section class="section-pad bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-black tracking-tight text-kom-ink sm:text-4xl">How can we help?</h2>
        <p class="mt-3 text-lg leading-relaxed text-kom-charcoal/70">Start with the kind of work—not a long list of unfamiliar categories.</p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <article class="group grid overflow-hidden rounded-xl border border-kom-charcoal/10 bg-white shadow-card transition-shadow hover:shadow-card-hover sm:grid-cols-[0.85fr_1.15fr]">
          <Image src={workerPortrait} alt="KOM USA maintenance team member" class="h-full min-h-64 w-full object-cover" widths={[420, 620]} sizes="(min-width: 1024px) 22vw, 100vw" loading="lazy" />
          <div class="flex flex-col justify-center p-7 sm:p-8"><h3 class="text-3xl font-black text-kom-field">Maintenance</h3><p class="mt-3 leading-relaxed text-kom-charcoal/70">Repairs, property upkeep, home systems, and handyman needs handled through one practical service path.</p><div class="mt-6 flex flex-wrap gap-x-5 gap-y-3"><a href="/maintenance/" class="inline-flex items-center gap-2 font-black text-kom-field">Explore Maintenance<ArrowRight class="size-4 transition-transform group-hover:translate-x-1" aria-hidden="true" /></a><a href={business.maintenancePhoneHref} class="inline-flex items-center gap-2 font-black text-kom-ink"><Phone class="size-4" aria-hidden="true" />{business.maintenancePhone}</a></div></div>
        </article>
        <article class="group grid overflow-hidden rounded-xl border border-kom-charcoal/10 bg-white shadow-card transition-shadow hover:shadow-card-hover sm:grid-cols-[0.85fr_1.15fr]">
          <Image src={interiorRenovation} alt="Completed KOM USA interior construction project" class="h-full min-h-64 w-full object-cover" widths={[420, 620]} sizes="(min-width: 1024px) 22vw, 100vw" loading="lazy" />
          <div class="flex flex-col justify-center p-7 sm:p-8"><h3 class="text-3xl font-black text-kom-field">Construction</h3><p class="mt-3 leading-relaxed text-kom-charcoal/70">Remodeling, building, materials, and larger project scopes for homeowners and contractors.</p><div class="mt-6 flex flex-wrap gap-x-5 gap-y-3"><a href="/construction/" class="inline-flex items-center gap-2 font-black text-kom-field">Explore Construction<ArrowRight class="size-4 transition-transform group-hover:translate-x-1" aria-hidden="true" /></a><a href={business.constructionPhoneHref} class="inline-flex items-center gap-2 font-black text-kom-ink"><Phone class="size-4" aria-hidden="true" />{business.constructionPhone}</a></div></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad bg-kom-warm-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center"><h2 class="text-3xl font-black tracking-tight text-kom-ink sm:text-4xl">Popular Maintenance services</h2><p class="mt-3 leading-relaxed text-kom-charcoal/70">Choose a starting point, call to confirm scope, or send one short request.</p></div>
      <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {popularMaintenance.map(({ service, icon }) => (
          <li>
            <a href={servicePath(service)} class="group flex h-full flex-col rounded-xl border border-kom-charcoal/10 bg-white p-6 shadow-card transition-all hover:-translate-y-0.5 hover:border-kom-field/30 hover:shadow-card-hover">
              <span class="flex size-12 items-center justify-center rounded-lg bg-kom-sage-tint text-kom-field transition-colors group-hover:bg-kom-field group-hover:text-white"><Icon name={icon} class="size-6" /></span>
              <h3 class="mt-5 text-xl font-black text-kom-ink">{service.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-kom-charcoal/65">{service.summary}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-black text-kom-field">Learn more<ArrowRight class="size-4 transition-transform group-hover:translate-x-1" aria-hidden="true" /></span>
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-8 text-center"><a href="/maintenance/" class="inline-flex min-h-11 items-center gap-2 rounded-md border-2 border-kom-field px-6 font-extrabold text-kom-field transition-colors hover:bg-kom-field hover:text-white">View all Maintenance services<ArrowRight class="size-4" aria-hidden="true" /></a></p>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="mx-auto grid max-w-7xl items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14 lg:px-8">
      <Image src={workerPortrait} alt="KOM USA team member ready for a Metro Detroit service request" class="aspect-[4/3] w-full rounded-xl object-cover shadow-lg" widths={[560, 800, 1100]} sizes="(min-width: 1024px) 50vw, 100vw" loading="lazy" />
      <div><h2 class="text-3xl font-black tracking-tight text-kom-ink text-balance sm:text-4xl">A local team built around straightforward decisions</h2><p class="mt-5 text-lg leading-relaxed text-kom-charcoal/72">KOM USA supports Metro Detroit homeowners and contractors with two clear service lines. Maintenance handles repairs and property upkeep; Construction handles remodeling, building, materials, and larger projects.</p><ul class="mt-6 space-y-3 text-kom-charcoal"><li class="flex gap-3"><Icon name="circle-check" class="mt-0.5 size-5 shrink-0 text-kom-field" /><span><strong>Clear service paths</strong> that reach the team responsible for the work.</span></li><li class="flex gap-3"><Icon name="circle-check" class="mt-0.5 size-5 shrink-0 text-kom-field" /><span><strong>Real project photography</strong> from Metro Detroit properties.</span></li><li class="flex gap-3"><Icon name="circle-check" class="mt-0.5 size-5 shrink-0 text-kom-field" /><span><strong>Plain communication</strong> about scope, pricing, and next steps.</span></li></ul><a href="/about/" class="mt-7 inline-flex items-center gap-2 font-black text-kom-field">Learn more about KOM USA<ArrowRight class="size-4" aria-hidden="true" /></a></div>
    </div>
  </section>

  <HowItWorks />
  <GoogleReviews />
  <Gallery />
  <ServiceArea />

  <section class="section-pad bg-kom-warm-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6"><AdaptiveRequestForm /></div>
  </section>
  <Faq />

  <section class="bg-kom-field py-16 text-white sm:py-20">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-7 px-4 text-center sm:px-6 lg:flex-row lg:px-8 lg:text-left">
      <div><h2 class="text-3xl font-black text-white sm:text-4xl">Ready to get the right team involved?</h2><p class="mt-3 max-w-2xl text-lg text-white/80">Call Maintenance, call Construction, or send one request for KOM USA to review.</p></div>
      <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row"><a href="/request-service/" class="inline-flex min-h-12 items-center justify-center rounded-md bg-white px-7 font-extrabold text-kom-field shadow-sm">Request Service</a><a href={business.maintenancePhoneHref} class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border-2 border-white/45 px-7 font-extrabold text-white hover:bg-white/10"><Phone class="size-5" aria-hidden="true" />{business.maintenancePhone}</a></div>
    </div>
  </section>
</BaseLayout>
