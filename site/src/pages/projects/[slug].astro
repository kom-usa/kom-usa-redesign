---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBand from "../../components/sections/CtaBand.astro";
import { getProject, getProjects } from "../../lib/sanity";
import { urlFor } from "../../lib/sanity-image";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project: any) => ({ params: { slug: project.slug } }));
}

const project = await getProject(Astro.params.slug!);
if (!project) return Astro.redirect("/404");

const photos = (project.photos ?? []) as unknown[];
const heroPhoto = photos[0];
const otherPhotos = photos.slice(1);
const metaTitle = project.seoTitle || `${project.title} | KOM USA Projects`;
const metaDescription = project.seoDescription || project.problem || `See this KOM USA project completed in Metro Detroit.`;
const ogImage = heroPhoto
  ? urlFor(heroPhoto).width(1200).height(630).fit("crop").auto("format").url()
  : undefined;
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={ogImage}>
  <article class="section-pad">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      {project.date && (
        <p class="reveal text-muted-foreground text-xs font-medium">
          {new Intl.DateTimeFormat("en-US", { dateStyle: "long" }).format(new Date(project.date))}
        </p>
      )}
      <h1 class="reveal text-kom-charcoal-deep mt-4 text-4xl leading-[1.05] font-black tracking-tight text-balance sm:text-5xl" style="--rd: 60ms">
        {project.title}
      </h1>

      {heroPhoto && (
        <img
          src={urlFor(heroPhoto).width(1400).auto("format").url()}
          alt={project.title}
          class="reveal mt-8 w-full rounded-xl object-cover shadow-card"
          style="--rd: 120ms"
          loading="eager"
        />
      )}

      {otherPhotos.length > 0 && (
        <div class="reveal mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3" style="--rd: 150ms">
          {otherPhotos.map((photo) => (
            <img
              src={urlFor(photo).width(700).height(500).fit("crop").auto("format").url()}
              alt={project.title}
              class="h-40 w-full rounded-lg object-cover shadow-card"
              loading="lazy"
            />
          ))}
        </div>
      )}

      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {project.problem && (
          <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 180ms">
            <h2 class="text-kom-charcoal-deep text-lg font-black">The problem</h2>
            <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{project.problem}</p>
          </div>
        )}
        {project.work && (
          <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 240ms">
            <h2 class="text-kom-charcoal-deep text-lg font-black">What we did</h2>
            <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{project.work}</p>
          </div>
        )}
        {project.result && (
          <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 300ms">
            <h2 class="text-kom-charcoal-deep text-lg font-black">The result</h2>
            <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{project.result}</p>
          </div>
        )}
      </div>
    </div>
  </article>

  <CtaBand />
</BaseLayout>
