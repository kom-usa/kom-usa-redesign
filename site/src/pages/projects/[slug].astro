---
import { getLiveStory } from "@storyblok/astro";

import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBand from "../../components/sections/CtaBand.astro";
import { getStories, getStory } from "../../lib/storyblok";

const serviceChipLabels: Record<string, string> = {
  locksmith: "Locksmith",
  "water-heaters": "Water heater",
  "chimney-care": "Chimney care",
  other: "Other",
};

export async function getStaticPaths() {
  const stories = await getStories("project");
  return stories.map((story) => ({ params: { slug: story.slug }, props: { story } }));
}

const liveStory = await getLiveStory(Astro);
let story = liveStory ?? (Astro.props as { story?: any }).story;
if (!story) {
  story = await getStory(`projects/${Astro.params.slug}`);
  if (!story) return Astro.redirect("/404");
}

const { content } = story;
const photos = (content.photos ?? []) as { filename: string; alt?: string }[];
const heroPhoto = photos[0];
const otherPhotos = photos.slice(1);

const metaTitle = content.seo_title || `${content.title} | KOM USA Projects`;
const metaDescription = content.seo_description || content.problem;
const ogImage: string | undefined = content.seo_image?.filename ?? heroPhoto?.filename;
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={ogImage}>
  <article class="section-pad">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p class="reveal flex flex-wrap items-center gap-3">
        {content.service_category && serviceChipLabels[content.service_category] && (
          <span class="bg-kom-sage-tint text-kom-field self-start rounded-full px-3 py-1 text-xs font-extrabold">
            {serviceChipLabels[content.service_category]}
          </span>
        )}
        {content.city && <span class="text-muted-foreground text-xs font-medium">{content.city}</span>}
      </p>
      <h1 class="reveal text-kom-charcoal-deep mt-4 text-4xl leading-[1.05] font-black tracking-tight text-balance sm:text-5xl" style="--rd: 60ms">
        {content.title}
      </h1>

      {heroPhoto?.filename && (
        <img
          src={heroPhoto.filename}
          alt={content.title}
          class="reveal mt-8 w-full rounded-xl object-cover shadow-card"
          style="--rd: 120ms"
          loading="eager"
        />
      )}

      {otherPhotos.length > 0 && (
        <div class="reveal mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3" style="--rd: 150ms">
          {otherPhotos.map((photo) => (
            <img
              src={photo.filename}
              alt={content.title}
              class="h-40 w-full rounded-lg object-cover shadow-card"
              loading="lazy"
            />
          ))}
        </div>
      )}

      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 180ms">
          <h2 class="text-kom-charcoal-deep text-lg font-black">The problem</h2>
          <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{content.problem}</p>
        </div>
        <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 240ms">
          <h2 class="text-kom-charcoal-deep text-lg font-black">What we did</h2>
          <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{content.work}</p>
        </div>
        <div class="reveal border-border rounded-xl border bg-white p-6 shadow-card" style="--rd: 300ms">
          <h2 class="text-kom-charcoal-deep text-lg font-black">The result</h2>
          <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{content.result}</p>
        </div>
      </div>
    </div>
  </article>

  <CtaBand />
</BaseLayout>
