---
import CircleCheck from "@tabler/icons/outline/circle-check.svg";
import Phone from "@tabler/icons/outline/phone.svg";

import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/starwind/button/Button.astro";
import { business } from "../data/business";
---

<BaseLayout
  title="Request received | KOM USA"
  description="Thanks for your service request. KOM USA will follow up shortly to confirm details and scheduling."
  noindex
>
  <section class="section-pad">
    <div class="mx-auto max-w-xl px-4 text-center sm:px-6">
      <span class="bg-kom-sage-tint text-primary mx-auto flex size-16 items-center justify-center rounded-full">
        <CircleCheck class="size-9" aria-hidden="true" />
      </span>
      <h1 class="text-kom-charcoal mt-6 text-3xl font-extrabold sm:text-4xl">
        Got it — your request is in.
      </h1>
      <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
        We'll call you back — usually the same business day — to talk it through and give you a
        quote. If anything is urgent in the meantime, call us directly.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={business.phoneHref} variant="primary" size="lg" class="font-bold">
          <Phone aria-hidden="true" />
          Call {business.phone}
        </Button>
        <Button href="/" variant="outline" size="lg" class="font-bold">
          Back to homepage
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
