---
import BaseLayout from "../layouts/BaseLayout.astro";
import TwoStepRequestForm from "../components/sections/TwoStepRequestForm.astro";
import { business } from "../data/business";
---

<BaseLayout title="Request Service or an Estimate | KOM USA" description="Send KOM USA a maintenance service request or construction estimate request for a Metro Detroit property or project.">
  <section class="bg-kom-field py-12 text-white sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="font-extrabold text-white/85">One request, routed to the right team</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black tracking-[-0.03em] text-balance sm:text-5xl">Request Service or an Estimate</h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-white/80">Two quick steps: tell us how to reach you, then choose Maintenance or Construction and describe the project. KOM USA will review the details and contact you about the next step.</p>
      <p class="mt-5 text-sm font-bold text-white/85">{business.availability}</p>
    </div>
  </section>
  <section class="section-pad bg-kom-warm-white"><div class="mx-auto max-w-5xl px-4 sm:px-6"><TwoStepRequestForm /></div></section>
</BaseLayout>
