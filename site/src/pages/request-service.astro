---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdaptiveRequestForm from "../components/sections/AdaptiveRequestForm.astro";
import { business } from "../data/business";
---

<BaseLayout title="Request Service or an Estimate | KOM USA" description="Send KOM USA a maintenance service request or construction estimate request for a Metro Detroit property or project.">
  <section class="bg-kom-ink py-12 text-white sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-kom-tan font-extrabold">One request, routed to the right team</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black tracking-[-0.03em] text-balance sm:text-5xl">Request Service or an Estimate</h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-white/75">Choose Maintenance or Construction, tell us what you need, and KOM USA will review the details and contact you about the next step.</p>
      <p class="mt-5 text-sm font-bold text-white/80">{business.availability}</p>
    </div>
  </section>
  <section class="section-pad bg-kom-cream"><div class="mx-auto max-w-6xl px-4 sm:px-6"><AdaptiveRequestForm /></div></section>
</BaseLayout>
