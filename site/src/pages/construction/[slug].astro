---
import ServiceDetailPage from "../../layouts/ServiceDetailPage.astro";
import { constructionServices } from "../../data/service-catalog";

export function getStaticPaths() {
  return constructionServices.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
---

<ServiceDetailPage {service} />
