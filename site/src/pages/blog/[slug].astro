---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PortableText from "../../sanity/PortableText.astro";
import { getArticle, getArticles } from "../../lib/sanity";
import { urlFor } from "../../lib/sanity-image";

export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map((article) => ({ params: { slug: article.slug } }));
}

const article = await getArticle(Astro.params.slug!);
if (!article) return Astro.redirect("/404");

const categoryLabels: Record<string, string> = {
  blog: "Blog post",
  update: "Company update",
};

const formattedDate = article.date
  ? new Intl.DateTimeFormat("en-US", { dateStyle: "long" }).format(new Date(article.date))
  : "";
const metaTitle = article.seoTitle || `${article.title} | KOM USA Blog`;
const metaDescription = article.seoDescription || article.excerpt || "News and updates from KOM USA in Metro Detroit.";
const ogImage = article.coverImage
  ? urlFor(article.coverImage).width(1200).height(630).fit("crop").auto("format").url()
  : undefined;
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={ogImage}>
  <article class="section-pad">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="reveal flex items-center gap-3">
        <span class="bg-kom-sage-tint text-kom-field self-start rounded-full px-3 py-1 text-xs font-extrabold">
          {categoryLabels[article.category ?? "blog"] ?? "Blog post"}
        </span>
        {formattedDate && <span class="text-muted-foreground text-xs font-medium">{formattedDate}</span>}
      </p>
      <h1 class="reveal text-kom-charcoal-deep mt-4 text-4xl leading-[1.05] font-black tracking-tight text-balance sm:text-5xl" style="--rd: 60ms">
        {article.title}
      </h1>

      {article.coverImage && (
        <img
          src={urlFor(article.coverImage).width(1200).auto("format").url()}
          alt={article.coverAlt || article.title}
          class="reveal mt-8 w-full rounded-xl object-cover shadow-card"
          style="--rd: 120ms"
          loading="eager"
        />
      )}

      <div class="reveal article-body text-kom-charcoal mt-8 max-w-none leading-relaxed" style="--rd: 150ms">
        <PortableText value={article.body} />
      </div>
    </div>
  </article>
</BaseLayout>
