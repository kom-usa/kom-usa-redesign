---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles } from "../../lib/sanity";
import { urlFor } from "../../lib/sanity-image";

const articles = await getArticles();

const categoryLabels: Record<string, string> = {
  blog: "Blog post",
  update: "Company update",
};

const dateFormatter = new Intl.DateTimeFormat("en-US", { dateStyle: "long" });
function formatDate(date?: string) {
  return date ? dateFormatter.format(new Date(date)) : "";
}
---

<BaseLayout
  title="Blog & Updates | KOM USA"
  description="Maintenance, construction, project, and company updates from the KOM USA team in Metro Detroit."
>
  <section class="section-pad">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-kom-field font-extrabold">From the crew</p>
        <h1 class="text-kom-ink mt-3 text-4xl font-black tracking-[-0.03em] text-balance sm:text-5xl">Blog & Updates</h1>
        <p class="mt-4 text-lg leading-relaxed text-kom-charcoal/70">Maintenance, construction, project, and company updates from KOM USA.</p>
      </div>

      {
        articles.length === 0 ? (
          <p class="reveal text-muted-foreground mt-12 text-center text-lg">No posts yet — check back soon.</p>
        ) : (
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {articles.map((article, index) => (
              <a
                href={`/blog/${article.slug}`}
                class="reveal border-border group flex flex-col overflow-hidden rounded-xl border bg-white transition-colors hover:border-kom-field/50 focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none"
                style={`--rd: ${index * 90}ms`}
              >
                {article.coverImage && (
                  <img
                    src={urlFor(article.coverImage).width(900).height(540).fit("crop").auto("format").url()}
                    alt={article.coverAlt || article.title}
                    class="h-48 w-full object-cover"
                    loading="lazy"
                  />
                )}
                <span class="flex flex-1 flex-col p-6">
                  <span class="flex items-center gap-3">
                    <span class="bg-kom-sage-tint text-kom-field self-start rounded-full px-3 py-1 text-xs font-extrabold">
                      {categoryLabels[article.category ?? "blog"] ?? "Blog post"}
                    </span>
                    {article.date && <span class="text-muted-foreground text-xs font-medium">{formatDate(article.date)}</span>}
                  </span>
                  <span class="text-kom-charcoal-deep group-hover:text-kom-field mt-3 text-xl font-black transition-colors">
                    {article.title}
                  </span>
                  {article.excerpt && (
                    <span class="text-muted-foreground mt-2 flex-1 text-sm leading-relaxed">{article.excerpt}</span>
                  )}
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
