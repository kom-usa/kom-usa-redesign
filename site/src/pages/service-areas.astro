---
import MapPin from "@tabler/icons/outline/map-pin.svg";
import BaseLayout from "../layouts/BaseLayout.astro";
import AdaptiveRequestForm from "../components/sections/AdaptiveRequestForm.astro";
import { business, serviceAreaCities, serviceAreaCounties } from "../data/business";
---

<BaseLayout title="Metro Detroit Service Areas | KOM USA" description="KOM USA provides maintenance and construction services across Wayne, Oakland, and Macomb counties in Metro Detroit.">
  <section class="bg-kom-ink py-14 text-white sm:py-20"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><p class="text-kom-tan font-extrabold">Wayne · Oakland · Macomb</p><h1 class="mt-3 max-w-4xl text-4xl font-black tracking-[-0.03em] text-balance sm:text-5xl lg:text-6xl">Maintenance and Construction Across Metro Detroit</h1><p class="mt-5 max-w-3xl text-lg leading-relaxed text-white/75">KOM USA serves homeowners, properties, and contractor projects throughout Metro Detroit. Include the job address or ZIP so the appropriate team can confirm coverage.</p></div></section>
  <section class="section-pad bg-white"><div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8"><div><h2 class="text-kom-ink text-3xl font-black">Three-county service area</h2><ul class="mt-6 space-y-3">{serviceAreaCounties.map((county) => <li class="text-kom-charcoal flex items-center gap-3 border-b border-kom-charcoal/15 pb-3 text-lg font-black"><MapPin class="text-kom-field size-5" aria-hidden="true" />{county}</li>)}</ul><p class="mt-6 leading-relaxed text-kom-charcoal/70">Service availability can vary by job type, travel, site access, and schedule. A city name on this page is not a promise of immediate dispatch.</p></div><div><h2 class="text-kom-ink text-3xl font-black">Communities commonly served</h2><ul class="mt-6 flex flex-wrap gap-2.5">{serviceAreaCities.map((city) => <li class="border border-kom-charcoal/15 bg-kom-warm-white px-4 py-2 text-sm font-bold text-kom-charcoal" style="border-radius: 999px;">{city}</li>)}</ul><p class="mt-6 leading-relaxed text-kom-charcoal/70">Don’t see your city? Submit the property location or call the appropriate team. Maintenance: <a class="text-kom-field font-black" href={business.maintenancePhoneHref}>{business.maintenancePhone}</a>. Construction: <a class="text-kom-field font-black" href={business.constructionPhoneHref}>{business.constructionPhone}</a>.</p></div></div></section>
  <section class="section-pad bg-kom-cream"><div class="mx-auto max-w-6xl px-4 sm:px-6"><AdaptiveRequestForm heading="Confirm Your Service Area" intro="Include the city or ZIP and the service needed. KOM USA will review the location with the project details." /></div></section>
</BaseLayout>
