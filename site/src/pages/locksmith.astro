---
import { Image } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";
import MessageCircle from "@tabler/icons/outline/message-circle.svg";
import Check from "@tabler/icons/outline/check.svg";
import InfoCircle from "@tabler/icons/outline/info-circle.svg";

import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/starwind/button/Button.astro";
import LockoutBand from "../components/sections/LockoutBand.astro";
import { business, locksmithNotes, locksmithPricing, serviceCategories } from "../data/business";
import doorLock from "../assets/images/door-lock.jpg";

const locksmithServices = serviceCategories.find((c) => c.id === "locksmith")?.items ?? [];
---

<BaseLayout
  title="Locksmith Services & Upfront Pricing in Metro Detroit | KOM USA"
  description="House and unit unlocks from $129, lock changes, smart keypads, and lock boxes across Metro Detroit — standard pricing published upfront. Call or text 313-804-0844."
>
  <section class="border-b bg-white">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-12 sm:px-6 md:py-16 lg:grid-cols-[1.5fr_1fr]">
      <div class="reveal">
        <p class="text-kom-field text-xs font-bold tracking-[0.18em] uppercase">
          Locksmith services · Metro Detroit
        </p>
        <h1 class="font-serif text-kom-ink mt-2 text-3xl font-bold text-balance sm:text-4xl lg:text-[2.75rem] lg:leading-[1.15]">
          Locked out? Upfront pricing, damage-free entry.
        </h1>
        <p class="text-muted-foreground mt-4 max-w-2xl text-lg leading-relaxed">
          Unlocks, lock changes, smart keypads, and lock boxes for homes, units, and rental
          portfolios — with standard pricing published before you book.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={business.phoneHref} variant="primary" size="lg" class="font-bold">
            <Phone aria-hidden="true" />
            Call {business.phone}
          </Button>
          <Button href={business.smsHref} variant="outline" size="lg" class="font-bold">
            <MessageCircle aria-hidden="true" />
            Text us
          </Button>
        </div>
        <p class="text-muted-foreground mt-4 text-sm">
          Lockouts are handled by phone so we can verify the property and dispatch after the 50%
          deposit.
        </p>
        <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm">
          {
            locksmithServices.map((item) => (
              <li class="text-kom-charcoal/90 flex items-center gap-1.5 font-medium">
                <Check class="text-kom-field size-4" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <figure class="reveal" style="--rd: 100ms">
        <Image
          src={doorLock}
          alt="Smart lock on a unit door controlled from a phone"
          class="w-full rounded-xl object-cover shadow-card"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 35vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </div>
  </section>

  <section id="pricing" class="section-pad scroll-mt-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="reveal bg-kom-field-deep overflow-hidden rounded-2xl p-6 sm:p-10">
        <h2 class="font-serif text-center text-3xl font-bold text-white sm:text-4xl">
          Transparent Pricing
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-center text-sm leading-relaxed text-white/75">
          Standard locksmith pricing for Metro Detroit homes, units, and rentals. Final pricing
          may vary based on lock hardware, door condition, and service details.
        </p>

        <div class="mt-8 overflow-hidden rounded-lg">
          <table class="w-full text-left">
            <caption class="sr-only">Locksmith services standard pricing</caption>
            <thead>
              <tr class="bg-kom-tan-light text-kom-ink">
                <th scope="col" class="px-5 py-3 text-sm font-bold">Service</th>
                <th scope="col" class="px-5 py-3 text-right text-sm font-bold">Standard price</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-kom-cream-deep bg-white/95">
              {
                locksmithPricing.map((item) => (
                  <tr>
                    <td class="px-5 py-3">
                      <p class="text-kom-ink text-sm font-bold">{item.service}</p>
                      {item.detail && (
                        <p class="text-muted-foreground mt-0.5 text-xs">{item.detail}</p>
                      )}
                    </td>
                    <td class="text-kom-field px-5 py-3 text-right text-base font-extrabold whitespace-nowrap">
                      {item.price}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div class="mt-6 rounded-lg bg-white/10 p-4">
          <h3 class="flex items-center gap-2 text-sm font-bold text-white">
            <InfoCircle class="text-kom-tan size-4.5" aria-hidden="true" />
            Before you book
          </h3>
          <ul class="mt-2 space-y-1.5 text-xs leading-relaxed text-white/80">
            {locksmithNotes.map((note) => <li>{note}</li>)}
          </ul>
        </div>

        <p class="mt-6 text-center">
          <a
            href={business.phoneHref}
            class="text-kom-field inline-flex items-center gap-2 rounded-md bg-white px-6 py-3 text-base font-bold transition-colors hover:bg-white/90 focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none"
          >
            <Phone class="size-5" aria-hidden="true" />
            Call {business.phone} to dispatch
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="font-serif text-kom-ink text-2xl font-bold sm:text-3xl">
        Not urgent? Plan it with a free quote.
      </h2>
      <p class="text-muted-foreground mx-auto mt-3 max-w-xl leading-relaxed">
        Lock changes, smart keypads, and lock boxes for turnovers or upgrades can be scheduled
        like any other job — send the request form and we'll follow up with a quote.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <Button href="/#request-service" variant="primary" size="lg" class="font-bold">
          Request service
        </Button>
        <Button href="/#faq" variant="outline" size="lg" class="font-bold">
          Read the FAQ
        </Button>
      </div>
    </div>
  </section>

  <LockoutBand />
</BaseLayout>
