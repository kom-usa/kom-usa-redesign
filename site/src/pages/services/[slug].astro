---
export function getStaticPaths() {
  return ["locksmith", "water-heaters", "chimney-care"].map((slug) => ({ params: { slug } }));
}

return Astro.redirect(({
  locksmith: "/maintenance/locksmith/",
  "water-heaters": "/maintenance/water-heaters/",
  "chimney-care": "/maintenance/chimney-care/",
} as Record<string, string>)[Astro.params.slug ?? ""] ?? "/maintenance/", 301);
---
