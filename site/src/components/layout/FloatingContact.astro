---
import Phone from "@tabler/icons/outline/phone.svg";
import ClipboardCheck from "@tabler/icons/outline/clipboard-check.svg";
import Headset from "@tabler/icons/outline/headset.svg";
import X from "@tabler/icons/outline/x.svg";

import { business } from "../../data/business";

/**
 * Desktop-only floating contact launcher (mobile uses MobileStickyBar).
 * Plain links only — no fake live-chat UI.
 * Primary action is a phone call; secondary is the /contact request form.
 */
const options = [
  { label: "Call", detail: business.phone, href: business.phoneHref, icon: Phone },
  { label: "Request a Call", detail: "Use the contact form", href: "/contact", icon: ClipboardCheck },
];
---

<div id="floating-contact" class="fixed right-5 bottom-5 z-50 hidden flex-col items-end gap-3 md:flex">
  <div
    id="floating-contact-panel"
    class="hidden w-72 overflow-hidden rounded-lg border border-kom-charcoal/10 bg-white shadow-card-hover"
    role="region"
    aria-label="Contact options"
  >
    <div class="bg-kom-field-deep px-4 py-4 text-white">
      <p class="text-sm font-black">Contact KOM</p>
      <p class="mt-1 text-xs text-white/70">Call now or request a call back.</p>
    </div>
    <ul class="divide-y divide-kom-charcoal/10">
      {
        options.map((option) => (
          <li>
            <a
              href={option.href}
              class="flex items-center gap-3 px-4 py-3.5 transition-colors hover:bg-kom-warm-white focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none focus-visible:ring-inset"
            >
              <span class="bg-kom-sage-tint text-kom-field flex size-10 shrink-0 items-center justify-center rounded-md">
                <option.icon class="size-4.5" aria-hidden="true" />
              </span>
              <span>
                <span class="text-kom-ink block text-sm font-bold">{option.label}</span>
                <span class="text-muted-foreground block text-xs">{option.detail}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <button
    type="button"
    id="floating-contact-toggle"
    aria-expanded="false"
    aria-controls="floating-contact-panel"
    class="bg-kom-field hover:bg-kom-field-hover flex items-center gap-2 rounded-full px-5 py-3 text-sm font-black text-white shadow-card-hover transition-colors focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none"
  >
    <Headset class="size-5" data-icon-open aria-hidden="true" />
    <X class="hidden size-5" data-icon-close aria-hidden="true" />
    Contact KOM
  </button>
</div>

<script>
  const root = document.getElementById("floating-contact");
  const toggle = document.getElementById("floating-contact-toggle");
  const panel = document.getElementById("floating-contact-panel");

  if (root && toggle && panel) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      panel.classList.toggle("hidden", !open);
      toggle.querySelector("[data-icon-open]")?.classList.toggle("hidden", open);
      toggle.querySelector("[data-icon-close]")?.classList.toggle("hidden", !open);
      if (open) panel.querySelector("a")?.focus();
    };
    const isOpen = () => toggle.getAttribute("aria-expanded") === "true";

    toggle.addEventListener("click", () => setOpen(!isOpen()));
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isOpen()) {
        setOpen(false);
        toggle.focus();
      }
    });
    document.addEventListener("click", (event) => {
      if (isOpen() && !root.contains(event.target as Node)) setOpen(false);
    });
  }
</script>
