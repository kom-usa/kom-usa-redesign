---
import Phone from "@tabler/icons/outline/phone.svg";
import ClipboardCheck from "@tabler/icons/outline/clipboard-check.svg";

import { business } from "../../data/business";
---

<div
  class="bg-background/95 fixed inset-x-0 bottom-0 z-50 border-t px-3 pt-2.5 backdrop-blur-sm md:hidden"
  style="padding-bottom: calc(0.625rem + env(safe-area-inset-bottom));"
>
  <div class="mx-auto flex max-w-md gap-2.5">
    <a
      href={business.phoneHref}
      class="bg-primary text-primary-foreground hover:bg-primary/90 focus-visible:ring-primary/50 flex h-12 flex-1 items-center justify-center gap-2 rounded-md text-base font-bold transition-colors focus-visible:ring-3 focus-visible:outline-none"
    >
      <Phone class="size-5" aria-hidden="true" />
      Call now
    </a>
    <a
      href="#request-service"
      class="bg-kom-charcoal hover:bg-kom-charcoal/90 focus-visible:ring-outline/50 flex h-12 flex-1 items-center justify-center gap-2 rounded-md text-base font-bold text-white transition-colors focus-visible:ring-3 focus-visible:outline-none"
    >
      <ClipboardCheck class="size-5" aria-hidden="true" />
      Request service
    </a>
  </div>
</div>
