---
import Phone from "@tabler/icons/outline/phone.svg";
import ChevronDown from "@tabler/icons/outline/chevron-down.svg";
import Menu2 from "@tabler/icons/outline/menu-2.svg";
import X from "@tabler/icons/outline/x.svg";
import { business } from "../../data/business";
import { maintenanceGroups, constructionLinks } from "../../data/service-catalog";
import logo from "../../assets/logos/kom-usa-logo-primary-charcoal.svg";

const mainLinks = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
  { label: "Service Areas", href: "/service-areas/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const linkClass = "rounded-md px-3 py-2 text-sm font-extrabold text-kom-charcoal transition-colors hover:bg-kom-sage-tint hover:text-kom-field focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40";
---

<div class="bg-kom-ink text-white">
  <div class="mx-auto flex min-h-10 max-w-7xl flex-wrap items-center justify-center gap-x-5 gap-y-1 px-4 py-2 text-xs font-bold sm:justify-between sm:px-6 lg:px-8">
    <p>{business.availability}</p>
    <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1">
      <a href={business.maintenancePhoneHref} data-phone-line="maintenance" class="inline-flex items-center gap-1.5 hover:text-kom-tan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-tan">
        <Phone class="size-3.5" aria-hidden="true" /> Maintenance: {business.maintenancePhone}
      </a>
      <a href={business.constructionPhoneHref} data-phone-line="construction" class="inline-flex items-center gap-1.5 hover:text-kom-tan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-tan">
        <Phone class="size-3.5" aria-hidden="true" /> Construction: {business.constructionPhone}
      </a>
    </div>
  </div>
</div>

<header class="sticky top-0 z-40 border-b border-kom-charcoal/10 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex min-h-18 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" aria-label="KOM USA home" class="shrink-0 rounded-sm focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40">
      <img src={logo.src} alt="KOM USA" class="h-12 w-auto" width="132" height="48" />
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-0.5 lg:flex">
      <a href="/" class={linkClass}>Home</a>

      <details class="group relative" data-nav-details>
        <summary class:list={[linkClass, "flex cursor-pointer list-none items-center gap-1"]}>
          Maintenance <ChevronDown class="size-4 transition-transform group-open:rotate-180" aria-hidden="true" />
        </summary>
        <div class="absolute top-[calc(100%+0.8rem)] left-1/2 w-[min(920px,92vw)] -translate-x-[37%] border border-kom-charcoal/15 bg-white p-6" style="border-radius: 14px;">
          <div class="grid grid-cols-5 gap-6">
            {maintenanceGroups.map((group) => (
              <div>
                <p class="text-kom-ink border-b border-kom-charcoal/10 pb-2 text-sm font-black">{group.label}</p>
                <ul class="mt-2 space-y-0.5">
                  {group.links.map((item) => <li><a href={item.href} class="text-kom-charcoal/80 hover:text-kom-field block rounded px-1 py-1.5 text-sm font-bold leading-snug focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-field/40">{item.label}</a></li>)}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </details>

      <details class="group relative" data-nav-details>
        <summary class:list={[linkClass, "flex cursor-pointer list-none items-center gap-1"]}>
          Construction <ChevronDown class="size-4 transition-transform group-open:rotate-180" aria-hidden="true" />
        </summary>
        <div class="absolute top-[calc(100%+0.8rem)] left-1/2 w-72 -translate-x-1/2 border border-kom-charcoal/15 bg-white p-3" style="border-radius: 14px;">
          <ul>
            {constructionLinks.map((item) => <li><a href={item.href} class="text-kom-charcoal/80 hover:bg-kom-sage-tint hover:text-kom-field block rounded-md px-3 py-2 text-sm font-bold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-field/40">{item.label}</a></li>)}
          </ul>
        </div>
      </details>

      {mainLinks.slice(1).map((item) => <a href={item.href} class={linkClass}>{item.label}</a>)}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/request-service/" class="bg-kom-field hover:bg-kom-field-hover hidden h-11 items-center justify-center rounded-md px-5 text-sm font-extrabold text-white transition-colors focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40 sm:inline-flex">
        Request Service
      </a>
      <button type="button" id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu" class="text-kom-charcoal hover:bg-kom-sage-tint flex size-11 items-center justify-center rounded-md focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40 lg:hidden">
        <Menu2 class="size-7" data-open-icon aria-hidden="true" />
        <X class="hidden size-7" data-close-icon aria-hidden="true" />
      </button>
    </div>
  </div>

  <nav id="mobile-menu" aria-label="Mobile" class="hidden max-h-[calc(100vh-7rem)] overflow-y-auto border-t border-kom-charcoal/10 bg-white lg:hidden">
    <div class="mx-auto max-w-3xl px-4 py-4 sm:px-6">
      <a href="/" class="text-kom-ink block rounded-md px-3 py-3 font-extrabold hover:bg-kom-sage-tint">Home</a>
      <details class="border-t border-kom-charcoal/10">
        <summary class="text-kom-ink flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 font-extrabold hover:bg-kom-sage-tint">
          Maintenance <ChevronDown class="size-5" aria-hidden="true" />
        </summary>
        <div class="pb-3 pl-3">
          {maintenanceGroups.map((group) => (
            <div class="mt-3">
              <p class="text-kom-charcoal/60 px-3 text-xs font-black">{group.label}</p>
              {group.links.map((item) => <a href={item.href} class="text-kom-charcoal hover:text-kom-field block rounded-md px-3 py-2 text-sm font-bold">{item.label}</a>)}
            </div>
          ))}
        </div>
      </details>
      <details class="border-t border-kom-charcoal/10">
        <summary class="text-kom-ink flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 font-extrabold hover:bg-kom-sage-tint">
          Construction <ChevronDown class="size-5" aria-hidden="true" />
        </summary>
        <div class="pb-3 pl-3">
          {constructionLinks.map((item) => <a href={item.href} class="text-kom-charcoal hover:text-kom-field block rounded-md px-3 py-2 text-sm font-bold">{item.label}</a>)}
        </div>
      </details>
      {mainLinks.slice(1).map((item) => <a href={item.href} class="text-kom-ink block border-t border-kom-charcoal/10 px-3 py-3 font-extrabold">{item.label}</a>)}
      <a href="/request-service/" class="bg-kom-field mt-3 flex h-12 items-center justify-center rounded-md px-5 font-extrabold text-white">Request Service</a>
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const setMenu = (open: boolean) => {
    menuToggle?.setAttribute("aria-expanded", String(open));
    menuToggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    mobileMenu?.classList.toggle("hidden", !open);
    menuToggle?.querySelector("[data-open-icon]")?.classList.toggle("hidden", open);
    menuToggle?.querySelector("[data-close-icon]")?.classList.toggle("hidden", !open);
  };
  menuToggle?.addEventListener("click", () => setMenu(menuToggle.getAttribute("aria-expanded") !== "true"));
  mobileMenu?.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).closest("a")) setMenu(false);
  });
  document.addEventListener("click", (event) => {
    document.querySelectorAll<HTMLDetailsElement>("[data-nav-details][open]").forEach((detail) => {
      if (!detail.contains(event.target as Node)) detail.open = false;
    });
  });
  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    setMenu(false);
    document.querySelectorAll<HTMLDetailsElement>("[data-nav-details][open]").forEach((detail) => detail.open = false);
  });

  document.querySelectorAll<HTMLAnchorElement>("[data-phone-line]").forEach((link) => {
    link.addEventListener("click", () => {
      const w = window as typeof window & { dataLayer?: Record<string, unknown>[] };
      (w.dataLayer ??= []).push({ event: "phone_click", service_line: link.dataset.phoneLine, source_page: window.location.pathname });
    });
  });
</script>
