---
import Phone from "@tabler/icons/outline/phone.svg";
import Mail from "@tabler/icons/outline/mail.svg";

import Button from "../starwind/button/Button.astro";
import { business } from "../../data/business";
import logoWhite from "../../assets/logos/kom-usa-logo-white.svg";

const nav = [
  { label: "Services", href: "#services" },
  { label: "Pricing", href: "#locksmith-pricing" },
  { label: "Property managers", href: "#property-management" },
  { label: "Service area", href: "#service-area" },
  { label: "FAQ", href: "#faq" },
];
---

<header class="bg-kom-field sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 rounded-sm focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none"
      aria-label={`${business.name} home`}
    >
      <img src={logoWhite.src} alt={business.name} class="h-11 w-auto md:h-12" width="86" height="63" />
    </a>

    <nav aria-label="Main" class="hidden items-center gap-6 lg:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-sm text-sm font-bold text-white/90 transition-colors hover:text-white focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={business.emailHref}
        class="hidden items-center gap-1.5 rounded-sm text-sm font-medium text-white/80 transition-colors hover:text-white focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none xl:flex"
      >
        <Mail class="size-4" aria-hidden="true" />
        {business.email}
      </a>
      <Button
        href={business.phoneHref}
        size="sm"
        class="border border-white/40 bg-transparent font-bold text-white hover:bg-white/10 focus-visible:ring-white/40"
      >
        <Phone aria-hidden="true" />
        <span class="hidden sm:inline">{business.phone}</span>
        <span class="sm:hidden">Call</span>
      </Button>
      <Button
        href="#request-service"
        size="sm"
        class="text-kom-field bg-white font-bold hover:bg-white/90 focus-visible:ring-white/50"
      >
        Request service
      </Button>
    </div>
  </div>
</header>
