---
import Phone from "@tabler/icons/outline/phone.svg";
import Menu2 from "@tabler/icons/outline/menu-2.svg";
import X from "@tabler/icons/outline/x.svg";
import ChevronDown from "@tabler/icons/outline/chevron-down.svg";
import { business } from "../../data/business";
import { maintenanceServices, constructionServices, servicePath } from "../../data/service-catalog";
import logo from "../../assets/logos/kom-usa-logo-primary-charcoal.svg";

interface NavChild {
  label: string;
  href: string;
}
interface NavItem {
  label: string;
  href: string;
  children?: NavChild[];
}

const nav: NavItem[] = [
  { label: "Home", href: "/" },
  {
    label: "Maintenance",
    href: "/maintenance/",
    children: [
      { label: "All Maintenance Services", href: "/maintenance/" },
      ...maintenanceServices.map((service) => ({ label: service.title, href: servicePath(service) })),
    ],
  },
  {
    label: "Construction",
    href: "/construction/",
    children: [
      { label: "Construction Overview", href: "/construction/" },
      ...constructionServices.map((service) => ({ label: service.title, href: servicePath(service) })),
      { label: "Home Building Materials", href: "/home-building-materials/" },
    ],
  },
  { label: "Projects", href: "/projects/" },
  { label: "Service Areas", href: "/service-areas/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 w-full border-b border-kom-charcoal/10 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex min-h-18 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" aria-label="KOM USA home" class="shrink-0 rounded-sm focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40">
      <img src={logo.src} alt="KOM USA" class="h-11 w-auto sm:h-12" width="132" height="48" />
    </a>

    <nav aria-label="Primary" class="hidden items-center lg:flex">
      {nav.map((item) =>
        item.children ? (
          <div class="group relative">
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "inline-flex items-center gap-1 rounded-md px-2.5 py-2 text-sm font-extrabold transition-colors focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/35 xl:px-3",
                isActive(item.href)
                  ? "bg-kom-sage-tint text-kom-field"
                  : "text-kom-charcoal/75 hover:bg-kom-warm-white hover:text-kom-ink",
              ]}
            >
              {item.label}
              <ChevronDown class="size-3.5 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true" />
            </a>
            <div class="invisible absolute left-1/2 top-full z-50 -translate-x-1/2 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
              <ul class="max-h-[calc(100vh-7rem)] w-72 overflow-y-auto rounded-xl border border-kom-charcoal/10 bg-white p-2 shadow-card-hover">
                {item.children.map((child, index) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        "block rounded-md px-3 py-2 text-sm font-bold text-kom-charcoal transition-colors hover:bg-kom-sage-tint hover:text-kom-field focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-field/40",
                        index === 0 && "border-b border-kom-charcoal/10 pb-2.5 mb-1.5 text-kom-field",
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "rounded-md px-2.5 py-2 text-sm font-extrabold transition-colors focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/35 xl:px-3",
              isActive(item.href)
                ? "bg-kom-sage-tint text-kom-field"
                : "text-kom-charcoal/75 hover:bg-kom-warm-white hover:text-kom-ink",
            ]}
          >
            {item.label}
          </a>
        ),
      )}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={business.maintenancePhoneHref}
        data-phone-line="maintenance"
        class="hidden items-center gap-1.5 text-sm font-black text-kom-ink transition-colors hover:text-kom-field xl:flex"
      >
        <Phone class="size-4 text-kom-field" aria-hidden="true" />
        {business.maintenancePhone}
      </a>
      <a href="/request-service/" class="hidden min-h-11 items-center justify-center rounded-md bg-kom-field px-5 text-sm font-extrabold text-white transition-colors hover:bg-kom-field-hover focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40 sm:inline-flex">
        Request Service
      </a>
      <button type="button" id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu" class="flex size-11 items-center justify-center rounded-md text-kom-charcoal hover:bg-kom-sage-tint focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40 lg:hidden">
        <Menu2 class="size-7" data-open-icon aria-hidden="true" />
        <X class="hidden size-7" data-close-icon aria-hidden="true" />
      </button>
    </div>
  </div>

  <nav id="mobile-menu" aria-label="Mobile" class="hidden max-h-[calc(100vh-4.5rem)] overflow-y-auto border-t border-kom-charcoal/10 bg-white lg:hidden">
    <div class="mx-auto max-w-3xl px-4 py-4 sm:px-6">
      {nav.map((item) =>
        item.children ? (
          <details class="group/details">
            <summary
              class:list={[
                "flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 font-extrabold [&::-webkit-details-marker]:hidden",
                isActive(item.href) ? "bg-kom-sage-tint text-kom-field" : "text-kom-ink hover:bg-kom-warm-white",
              ]}
            >
              {item.label}
              <ChevronDown class="size-4 transition-transform group-open/details:rotate-180" aria-hidden="true" />
            </summary>
            <ul class="mt-1 mb-2 space-y-0.5 border-l-2 border-kom-sage-tint pl-4">
              {item.children.map((child) => (
                <li><a href={child.href} class="block rounded-md px-3 py-2 text-sm font-bold text-kom-charcoal hover:bg-kom-warm-white hover:text-kom-field">{child.label}</a></li>
              ))}
            </ul>
          </details>
        ) : (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "block rounded-md px-3 py-3 font-extrabold",
              isActive(item.href) ? "bg-kom-sage-tint text-kom-field" : "text-kom-ink hover:bg-kom-warm-white",
            ]}
          >
            {item.label}
          </a>
        ),
      )}
      <div class="mt-3 grid gap-2 border-t border-kom-charcoal/10 pt-4 sm:grid-cols-2">
        <a href={business.maintenancePhoneHref} data-phone-line="maintenance" class="flex min-h-12 items-center justify-center gap-2 rounded-md border border-kom-charcoal/15 font-black text-kom-ink">
          <Phone class="size-4 text-kom-field" aria-hidden="true" />Maintenance {business.maintenancePhone}
        </a>
        <a href={business.constructionPhoneHref} data-phone-line="construction" class="flex min-h-12 items-center justify-center gap-2 rounded-md border border-kom-charcoal/15 font-black text-kom-ink">
          <Phone class="size-4 text-kom-field" aria-hidden="true" />Construction {business.constructionPhone}
        </a>
      </div>
      <a href="/request-service/" class="mt-3 flex min-h-12 items-center justify-center rounded-md bg-kom-field px-5 font-extrabold text-white">Request Service</a>
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const setMenu = (open: boolean) => {
    menuToggle?.setAttribute("aria-expanded", String(open));
    menuToggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    mobileMenu?.classList.toggle("hidden", !open);
    menuToggle?.querySelector("[data-open-icon]")?.classList.toggle("hidden", open);
    menuToggle?.querySelector("[data-close-icon]")?.classList.toggle("hidden", !open);
  };

  menuToggle?.addEventListener("click", () => setMenu(menuToggle.getAttribute("aria-expanded") !== "true"));
  mobileMenu?.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).closest("a")) setMenu(false);
  });
  window.addEventListener("resize", () => {
    if (window.matchMedia("(min-width: 1024px)").matches) setMenu(false);
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });

  document.querySelectorAll<HTMLAnchorElement>("[data-phone-line]").forEach((link) => {
    link.addEventListener("click", () => {
      const w = window as typeof window & { dataLayer?: Record<string, unknown>[] };
      (w.dataLayer ??= []).push({ event: "phone_click", service_line: link.dataset.phoneLine, source_page: window.location.pathname });
    });
  });
</script>
