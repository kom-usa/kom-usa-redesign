---
import Phone from "@tabler/icons/outline/phone.svg";
import Mail from "@tabler/icons/outline/mail.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";

import { business, serviceCategories } from "../../data/business";
import logoWhite from "../../assets/logos/kom-usa-logo-white.svg";

const year = new Date().getFullYear();

const quickLinks = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/#services" },
  { label: "Locksmith pricing", href: "/locksmith#pricing" },
  { label: "Property managers", href: "/#property-management" },
  { label: "Service area", href: "/#service-area" },
  { label: "About", href: "/about" },
  { label: "FAQ", href: "/#faq" },
];

const linkClass =
  "text-white/80 transition-colors hover:text-kom-tan focus-visible:ring-3 focus-visible:ring-kom-tan/60 focus-visible:outline-none rounded-sm";
---

<footer class="bg-kom-ink text-white">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <h2 class="text-sm font-bold text-white">Contact Us</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a href={business.phoneHref} class:list={["flex items-center gap-2.5 font-bold text-white", linkClass]}>
              <Phone class="size-4 text-kom-tan" aria-hidden="true" />
              {business.phone}
            </a>
          </li>
          <li>
            <a href={business.emailHref} class:list={["flex items-center gap-2.5", linkClass]}>
              <Mail class="size-4 text-kom-tan" aria-hidden="true" />
              {business.email}
            </a>
          </li>
          <li class="flex items-center gap-2.5 text-white/80">
            <MapPin class="size-4 text-kom-tan" aria-hidden="true" />
            Serving {business.serviceArea}, Michigan
          </li>
        </ul>
      </div>

      <nav aria-label="Quick links">
        <h2 class="text-sm font-bold text-white">Quick Links</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            quickLinks.map((link) => (
              <li>
                <a href={link.href} class={linkClass}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Services">
        <h2 class="text-sm font-bold text-white">Services</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            serviceCategories.map((category) => (
              <li>
                <a
                  href={category.id === "locksmith" ? "/locksmith" : `/#${category.id}`}
                  class={linkClass}
                >
                  {category.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="text-sm font-bold text-white">Get your free quote</h2>
        <p class="mt-4 text-sm leading-relaxed text-white/70">
          One local crew for construction, maintenance, locksmith, and chimney care across Metro
          Detroit.
        </p>
        <a
          href="/#quick-quote"
          class="bg-kom-field hover:bg-kom-field-hover mt-5 inline-flex items-center justify-center rounded-md px-5 py-2.5 text-sm font-bold text-white transition-colors focus-visible:ring-3 focus-visible:ring-kom-tan/60 focus-visible:outline-none"
        >
          Get your free quote
        </a>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="flex items-center gap-3">
        <img src={logoWhite.src} alt="" class="h-8 w-auto opacity-80" width="57" height="42" />
        © {year} {business.name}. All rights reserved.
      </p>
      <p>Locksmith standard pricing shown on this site — final pricing may vary by job.</p>
    </div>
  </div>
</footer>
