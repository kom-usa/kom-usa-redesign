---
import Phone from "@tabler/icons/outline/phone.svg";
import Mail from "@tabler/icons/outline/mail.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import Clock from "@tabler/icons/outline/clock.svg";
import { business } from "../../data/business";
import logoWhite from "../../assets/logos/kom-usa-logo-white.svg";

const year = new Date().getFullYear();
const links = [
  { label: "Maintenance", href: "/maintenance/" },
  { label: "Construction", href: "/construction/" },
  { label: "Handyman Services", href: "/maintenance/handyman-services/" },
  { label: "Home Building Materials", href: "/home-building-materials/" },
  { label: "Projects", href: "/projects/" },
  { label: "Service Areas", href: "/service-areas/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
  { label: "Subscription Maintenance — Coming Soon", href: "/maintenance/subscription-maintenance/" },
  { label: "Privacy Policy", href: "/privacy/" },
];
const linkClass = "rounded-sm text-white/75 transition-colors hover:text-kom-tan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-tan";
---

<footer class="bg-kom-ink text-white">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <img src={logoWhite.src} alt="KOM USA" class="h-14 w-auto" width="150" height="55" />
        <p class="mt-5 max-w-md text-sm leading-relaxed text-white/70">
          Home maintenance, repairs, remodeling, construction, and project support across Metro Detroit for homeowners and contractors.
        </p>
        <p class="mt-5 inline-flex items-center gap-2 text-sm font-bold"><Clock class="size-4 text-kom-tan" aria-hidden="true" />{business.availability}</p>
      </div>

      <div>
        <h2 class="text-base font-black">Call the right team</h2>
        <div class="mt-4 space-y-4 text-sm">
          <a href={business.maintenancePhoneHref} class:list={["block", linkClass]}>
            <span class="text-white/55 block text-xs">Maintenance Phone</span>
            <span class="mt-1 flex items-center gap-2 font-black text-white"><Phone class="size-4 text-kom-tan" aria-hidden="true" />{business.maintenancePhone}</span>
          </a>
          <a href={business.constructionPhoneHref} class:list={["block", linkClass]}>
            <span class="text-white/55 block text-xs">Construction Phone</span>
            <span class="mt-1 flex items-center gap-2 font-black text-white"><Phone class="size-4 text-kom-tan" aria-hidden="true" />{business.constructionPhone}</span>
          </a>
          <a href={business.emailHref} class:list={["flex items-center gap-2", linkClass]}><Mail class="size-4 text-kom-tan" aria-hidden="true" />{business.email}</a>
          <p class="flex items-start gap-2 text-white/70"><MapPin class="mt-0.5 size-4 shrink-0 text-kom-tan" aria-hidden="true" />Serving Metro Detroit, including communities across Wayne, Oakland, and Macomb counties.</p>
        </div>
      </div>

      <nav aria-label="Footer">
        <h2 class="text-base font-black">Explore KOM USA</h2>
        <ul class="mt-4 grid grid-cols-2 gap-x-5 gap-y-2.5 text-sm">
          {links.map((link) => <li><a href={link.href} class={linkClass}>{link.label}</a></li>)}
        </ul>
      </nav>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {business.name}. All rights reserved.</p>
      <p>Request details are reviewed before scope, pricing, or scheduling is confirmed.</p>
    </div>
  </div>
</footer>
