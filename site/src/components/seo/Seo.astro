---
import {
  business,
  googleReviews,
  serviceAreaCities,
  faqs as homepageFaqs,
} from "../../data/business";
import { allServices } from "../../data/service-catalog";
import { getReviewStats } from "../../lib/google-reviews";

interface Props {
  title: string;
  description: string;
  /** Path to a 1200×630 image inside /public, e.g. "/og/home.jpg" */
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  /** Include expanded offers, rating, and FAQ entities (homepage only). */
  includeBusinessGraph?: boolean;
  /** Adds a city-specific Service entity without implying a separate office. */
  serviceAreaCity?: string;
}

const {
  title,
  description,
  ogImage = "/og/home.jpg",
  ogImageAlt = `${business.name} — ${business.tagline}`,
  noindex = false,
  includeBusinessGraph = false,
  serviceAreaCity,
} = Astro.props;

const site = Astro.site ?? new URL(business.url);
const canonical = new URL(Astro.url.pathname, site).href;
const ogImageUrl = new URL(ogImage, site).href;

const ids = {
  website: new URL("/#website", site).href,
  business: new URL("/#business", site).href,
  webpage: `${canonical}#webpage`,
  faq: `${canonical}#faq`,
  service: `${canonical}#service`,
  logo: new URL("/#logo", site).href,
};

const serviceList = includeBusinessGraph ? allServices : [];
const faqList = includeBusinessGraph ? homepageFaqs : [];
const reviewStats = includeBusinessGraph ? await getReviewStats() : null;

const localBusiness: Record<string, unknown> = {
  "@type": ["LocalBusiness", "GeneralContractor"],
  "@id": ids.business,
  name: business.name,
  legalName: business.legalName,
  url: site.href,
  telephone: business.phone,
  email: business.email,
  contactPoint: [
    {
      "@type": "ContactPoint",
      telephone: business.maintenancePhone,
      contactType: "maintenance service",
      areaServed: "Metro Detroit",
    },
    {
      "@type": "ContactPoint",
      telephone: business.constructionPhone,
      contactType: "construction estimates",
      areaServed: "Metro Detroit",
    },
  ],
  image: ogImageUrl,
  logo: {
    "@type": "ImageObject",
    "@id": ids.logo,
    url: new URL("/logo.svg", site).href,
  },
  areaServed: [
    { "@type": "AdministrativeArea", name: "Metro Detroit, Michigan" },
    ...serviceAreaCities.map((city) => ({
      "@type": "City",
      name: `${city}, MI`,
    })),
  ],
  sameAs: [googleReviews.url, business.instagramUrl],
};

if (includeBusinessGraph) {
  Object.assign(localBusiness, {
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: reviewStats?.rating ?? googleReviews.rating,
      reviewCount: String(reviewStats?.count ?? googleReviews.count),
    },
    knowsAbout: serviceList.map((service) => service.title),
    makesOffer: serviceList.map((service) => ({
      "@type": "Offer",
      itemOffered: { "@type": "Service", name: service.title },
    })),
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "KOM USA maintenance and construction services",
      itemListElement: serviceList.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service.title,
          serviceType: service.line === "maintenance" ? "Home maintenance" : "Residential construction",
        },
      })),
    },
  });
}

const graph: Record<string, unknown>[] = [
  {
    "@type": "WebSite",
    "@id": ids.website,
    url: site.href,
    name: business.name,
    publisher: { "@id": ids.business },
  },
  {
    "@type": "WebPage",
    "@id": ids.webpage,
    url: canonical,
    name: title,
    description,
    isPartOf: { "@id": ids.website },
    about: { "@id": ids.business },
    primaryImageOfPage: { "@type": "ImageObject", url: ogImageUrl },
  },
  localBusiness,
];

if (includeBusinessGraph) {
  graph.push(
    {
      "@type": "FAQPage",
      "@id": ids.faq,
      mainEntity: faqList.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    },
  );
}

if (serviceAreaCity) {
  graph.push({
    "@type": "Service",
    "@id": ids.service,
    name: `Home maintenance and construction in ${serviceAreaCity}`,
    description,
    url: canonical,
    provider: { "@id": ids.business },
    areaServed: { "@type": "City", name: `${serviceAreaCity}, MI` },
    serviceType: "Home maintenance, handyman, remodeling, and construction",
  });
}

const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": graph });
---

<title>{title}</title>
<meta name="description" content={description} />
{!noindex && <link rel="canonical" href={canonical} />}
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={business.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />

<script is:inline type="application/ld+json" set:html={jsonLd} />
