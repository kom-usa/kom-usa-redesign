---
/**
 * Maps a data-driven icon name (see src/data/business.ts) to a Tabler outline icon.
 */
import CalendarCheck from "@tabler/icons/outline/calendar-check.svg";
import CircleCheck from "@tabler/icons/outline/circle-check.svg";
import ClipboardCheck from "@tabler/icons/outline/clipboard-check.svg";
import HomeHeart from "@tabler/icons/outline/home-heart.svg";
import MessageCircle from "@tabler/icons/outline/message-circle.svg";
import Phone from "@tabler/icons/outline/phone.svg";
import ShieldCheck from "@tabler/icons/outline/shield-check.svg";
import Tool from "@tabler/icons/outline/tool.svg";
import Droplet from "@tabler/icons/outline/droplet.svg";
import Lock from "@tabler/icons/outline/lock.svg";
import Flame from "@tabler/icons/outline/flame.svg";
import Wind from "@tabler/icons/outline/wind.svg";
import Brush from "@tabler/icons/outline/brush.svg";
import Temperature from "@tabler/icons/outline/temperature.svg";
import Bolt from "@tabler/icons/outline/bolt.svg";
import Wall from "@tabler/icons/outline/wall.svg";
import BucketDroplet from "@tabler/icons/outline/bucket-droplet.svg";
import Fence from "@tabler/icons/outline/fence.svg";
import HomeShield from "@tabler/icons/outline/home-shield.svg";
import Texture from "@tabler/icons/outline/texture.svg";
import Window from "@tabler/icons/outline/window.svg";
import Trowel from "@tabler/icons/outline/trowel.svg";
import Ladder from "@tabler/icons/outline/ladder.svg";
import Trash from "@tabler/icons/outline/trash.svg";
import ChefHat from "@tabler/icons/outline/chef-hat.svg";
import Bath from "@tabler/icons/outline/bath.svg";
import LayoutGrid from "@tabler/icons/outline/layout-grid.svg";
import Ruler2 from "@tabler/icons/outline/ruler-2.svg";
import Shovel from "@tabler/icons/outline/shovel.svg";
import Paint from "@tabler/icons/outline/paint.svg";
import Crane from "@tabler/icons/outline/crane.svg";
import Building from "@tabler/icons/outline/building.svg";
import Packages from "@tabler/icons/outline/packages.svg";

interface Props {
  name: string;
  class?: string;
}

const icons: Record<string, (props: Record<string, unknown>) => unknown> = {
  "calendar-check": CalendarCheck,
  "circle-check": CircleCheck,
  "clipboard-check": ClipboardCheck,
  "home-heart": HomeHeart,
  "message-circle": MessageCircle,
  phone: Phone,
  "shield-check": ShieldCheck,
  tool: Tool,
  droplet: Droplet,
  lock: Lock,
  flame: Flame,
  wind: Wind,
  brush: Brush,
  temperature: Temperature,
  bolt: Bolt,
  wall: Wall,
  "bucket-droplet": BucketDroplet,
  fence: Fence,
  "home-shield": HomeShield,
  texture: Texture,
  window: Window,
  trowel: Trowel,
  ladder: Ladder,
  trash: Trash,
  "chef-hat": ChefHat,
  bath: Bath,
  "layout-grid": LayoutGrid,
  "ruler-2": Ruler2,
  shovel: Shovel,
  paint: Paint,
  crane: Crane,
  building: Building,
  packages: Packages,
};

const { name, class: className } = Astro.props;
const IconComponent = icons[name] ?? CircleCheck;
---

<IconComponent class={className} aria-hidden="true" />
