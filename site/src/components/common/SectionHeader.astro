---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, lead, align = "center", class: className } = Astro.props;
---

<div
  class:list={[
    "reveal max-w-2xl",
    align === "center" && "mx-auto text-center",
    className,
  ]}
>
  {
    eyebrow && (
      <p class="text-primary text-xs font-bold tracking-[0.18em] uppercase">{eyebrow}</p>
    )
  }
  <h2 class="text-kom-ink mt-2 text-3xl font-black tracking-tight text-balance sm:text-4xl lg:text-[44px] lg:leading-[1.1]">
    {title}
  </h2>
  {lead && <p class="text-muted-foreground mt-4 text-lg leading-relaxed">{lead}</p>}
</div>
