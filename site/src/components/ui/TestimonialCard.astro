---
import StarFilled from "@tabler/icons/filled/star.svg";

interface Props {
  name: string;
  role: string;
  testimonial: string;
  rating?: number;
  image?: string;
  authorUrl?: string;
  reviewUrl: string;
  class?: string;
  style?: string;
}

const {
  name,
  role,
  testimonial,
  rating = 5,
  image,
  authorUrl,
  reviewUrl,
  class: className,
  style,
} = Astro.props;

const normalizedRating = Math.max(0, Math.min(5, Math.round(rating)));
const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0])
  .join("")
  .toUpperCase();
---

<figure
  data-google-review
  class:list={[
    "reveal relative flex h-full min-h-72 flex-col overflow-hidden rounded-2xl border border-kom-field/10 bg-white p-6 transition-colors hover:border-kom-field/30 md:p-8",
    className,
  ]}
  style={style}
>
  <span
    class="pointer-events-none absolute top-4 right-6 font-serif text-7xl leading-none text-kom-charcoal/10"
    aria-hidden="true"
  >“</span>

  <div class="relative flex h-full flex-1 flex-col gap-5">
    <div class="flex gap-1" data-review-stars aria-label={`${normalizedRating} out of 5 stars`}>
      {
        Array.from({ length: 5 }).map((_, index) => (
          <StarFilled
            data-review-star
            class:list={[
              "size-4",
              index < normalizedRating ? "text-kom-brass" : "text-kom-concrete",
            ]}
            aria-hidden="true"
          />
        ))
      }
    </div>

    <blockquote class="text-kom-charcoal flex-1 text-base leading-relaxed text-pretty" data-review-text>
      {testimonial}
    </blockquote>

    <figcaption class="flex items-center gap-4">
      <span class="relative flex size-12 shrink-0 overflow-hidden rounded-full bg-kom-sage-tint">
        <img
          data-review-image
          src={image}
          alt={image ? `${name} profile photo` : ""}
          width="48"
          height="48"
          loading="lazy"
          referrerpolicy="no-referrer"
          class:list={["size-full object-cover", !image && "hidden"]}
        />
        <span
          data-review-initials
          class:list={[
            "text-kom-field flex size-full items-center justify-center text-sm font-black",
            image && "hidden",
          ]}
          aria-hidden="true"
        >{initials}</span>
      </span>

      <span class="min-w-0">
        <a
          data-review-author
          href={authorUrl ?? reviewUrl}
          target="_blank"
          rel="noopener"
          class="text-kom-charcoal-deep block truncate font-extrabold hover:text-kom-field hover:underline focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40"
        >{name}</a>
        <a
          data-review-source
          href={reviewUrl}
          target="_blank"
          rel="noopener"
          class="text-muted-foreground mt-0.5 block text-sm hover:text-kom-field hover:underline focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40"
        >{role}</a>
      </span>
    </figcaption>
  </div>
</figure>
