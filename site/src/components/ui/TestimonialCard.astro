---
import StarFilled from "@tabler/icons/filled/star.svg";
import { createReviewExcerpt } from "../../lib/review-excerpt";

interface Props {
  name: string;
  dateLabel?: string;
  testimonial: string;
  rating?: number;
  image?: string;
  authorUrl?: string;
  reviewUrl: string;
  class?: string;
  style?: string;
}

const {
  name,
  dateLabel,
  testimonial,
  rating = 5,
  image,
  authorUrl,
  reviewUrl,
  class: className,
  style,
} = Astro.props;

const normalizedRating = Math.max(0, Math.min(5, Math.round(rating)));
const excerpt = createReviewExcerpt(testimonial);
const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0])
  .join("")
  .toUpperCase();
---

<figure
  data-google-review
  class:list={[
    "reveal flex h-full min-h-80 flex-col overflow-hidden rounded-xl border border-kom-charcoal/10 bg-white p-6 transition-colors hover:border-kom-field/30",
    className,
  ]}
  style={style}
>
  <div class="flex items-start justify-between gap-4">
    <figcaption class="flex min-w-0 items-center gap-3">
      <span class="relative flex size-12 shrink-0 overflow-hidden rounded-full bg-kom-sage-tint">
        <img
          data-review-image
          src={image}
          alt={image ? `${name} profile photo` : ""}
          width="48"
          height="48"
          loading="lazy"
          referrerpolicy="no-referrer"
          class:list={["size-full object-cover", !image && "hidden"]}
        />
        <span
          data-review-initials
          class:list={[
            "text-kom-field flex size-full items-center justify-center text-sm font-black",
            image && "hidden",
          ]}
          aria-hidden="true"
        >{initials}</span>
      </span>

      <span class="min-w-0">
        <a
          data-review-author
          href={authorUrl ?? reviewUrl}
          target="_blank"
          rel="noopener"
          class="text-kom-charcoal-deep block truncate text-base font-extrabold hover:text-kom-field hover:underline focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40"
        >{name}</a>
        <span data-review-date class="text-muted-foreground mt-1 block text-sm">
          {dateLabel ?? "Google review"}
        </span>
      </span>
    </figcaption>

    <a
      data-review-source
      href={reviewUrl}
      target="_blank"
      rel="noopener"
      aria-label={`Read ${name}'s review on Google Maps`}
      class="shrink-0 rounded-sm focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40"
    >
      <svg class="size-6" viewBox="0 0 24 24" role="img" aria-label="Google">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.57c2.08-1.92 3.27-4.74 3.27-8.09Z" />
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.29-2.66l-3.57-2.76c-.99.66-2.24 1.05-3.72 1.05-2.87 0-5.3-1.93-6.16-4.52H2.15v2.85A11 11 0 0 0 12 23Z" />
        <path fill="#FBBC05" d="M5.84 14.11A6.62 6.62 0 0 1 5.5 12c0-.73.13-1.44.34-2.11V7.04H2.15A11 11 0 0 0 1 12c0 1.77.42 3.44 1.15 4.96l3.69-2.85Z" />
        <path fill="#EA4335" d="M12 5.37c1.62 0 3.06.56 4.2 1.64l3.17-3.17A10.64 10.64 0 0 0 12 1 11 11 0 0 0 2.15 7.04l3.69 2.85C6.7 7.3 9.13 5.37 12 5.37Z" />
      </svg>
    </a>
  </div>

  <div class="mt-5 flex gap-1" data-review-stars aria-label={`${normalizedRating} out of 5 stars`}>
      {
        Array.from({ length: 5 }).map((_, index) => (
          <StarFilled
            data-review-star
            class:list={[
              "size-4",
              index < normalizedRating ? "text-kom-field" : "text-kom-concrete",
            ]}
            aria-hidden="true"
          />
        ))
      }
  </div>

  <blockquote class="text-kom-charcoal mt-4 line-clamp-4 text-base leading-relaxed text-pretty" data-review-text>
    {excerpt}
  </blockquote>

  <a
    data-review-read-more
    href={reviewUrl}
    target="_blank"
    rel="noopener"
    class="text-kom-field mt-auto pt-5 text-sm font-extrabold hover:underline focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40"
  >Read more</a>
</figure>
