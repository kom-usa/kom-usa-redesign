---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"textarea">;

const { class: className, ...rest } = Astro.props;
---

<textarea
  class:list={[
    "peer min-h-10 w-full rounded-md border border-kom-concrete bg-transparent px-3 py-2 text-base text-kom-charcoal shadow-xs transition-[color,box-shadow] placeholder:text-muted-foreground focus-visible:border-kom-field focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:border-error aria-invalid:focus-visible:ring-error/40",
    className,
  ]}
  {...rest}></textarea>
