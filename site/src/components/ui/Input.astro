---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"input">;

const { class: className, ...rest } = Astro.props;
---

<input
  class:list={[
    "peer h-11 w-full rounded-md border border-kom-cream-border bg-transparent px-3 text-base text-kom-charcoal shadow-xs transition-[color,box-shadow] placeholder:text-muted-foreground focus-visible:border-kom-field focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:border-error aria-invalid:focus-visible:ring-error/40",
    className,
  ]}
  {...rest}
/>
