---
import { Image } from "astro:assets";
import CircleCheck from "@tabler/icons/outline/circle-check.svg";
import Phone from "@tabler/icons/outline/phone.svg";

import Button from "../starwind/button/Button.astro";
import { business, serviceCategories } from "../../data/business";
import apartmentBuilding from "../../assets/images/apartment-building.jpg";

const pmServices =
  serviceCategories.find((c) => c.id === "property-management")?.items ?? [];
---

<section id="property-management" class="section-pad scroll-mt-16 bg-kom-field-deep">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 sm:px-6 lg:grid-cols-[1.25fr_1fr] lg:gap-14">
    <div class="reveal">
      <p class="text-kom-tan text-xs font-bold tracking-[0.18em] uppercase">
        Property managers · Landlords · Investors
      </p>
      <h2 class="font-serif mt-2 text-3xl font-bold text-balance text-white sm:text-4xl">
        The maintenance arm for your rental portfolio.
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-white/75">
        Turnovers, access, and upkeep across a portfolio shouldn't take five vendors. One crew
        handles the work, one contact keeps you posted, and one invoice covers the job.
      </p>

      <ul class="mt-6 grid gap-x-6 gap-y-2.5 text-sm sm:grid-cols-2">
        {
          pmServices.map((item) => (
            <li class="flex items-start gap-2 font-medium text-white/90">
              <CircleCheck class="text-kom-sage mt-0.5 size-4.5 shrink-0" aria-hidden="true" />
              {item}
            </li>
          ))
        }
      </ul>

      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/#request-service" variant="primary" size="lg" class="font-bold">
          Request portfolio service
        </Button>
        <Button
          href={business.phoneHref}
          size="lg"
          class="border border-white/30 bg-transparent font-bold text-white hover:bg-white/10 focus-visible:ring-white/40"
        >
          <Phone aria-hidden="true" />
          Call {business.phone}
        </Button>
      </div>
      <p class="mt-4 text-sm text-white/60">
        B2B locksmith pricing available for management companies and real estate teams.
      </p>
    </div>

    <figure class="reveal" style="--rd: 120ms">
      <Image
        src={apartmentBuilding}
        alt="Apartment building with balconies"
        class="w-full rounded-xl object-cover shadow-card"
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 40vw, 100vw"
        loading="lazy"
      />
    </figure>
  </div>
</section>
