---
import { Image } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";

import Button from "../starwind/button/Button.astro";
import { business, serviceCategories } from "../../data/business";

import apartmentBuilding from "../../assets/images/apartment-building.jpg";
import basementInterior from "../../assets/images/basement-interior.jpg";
import doorLock from "../../assets/images/door-lock.jpg";

const pmServices =
  serviceCategories.find((c) => c.id === "property-management")?.items ?? [];

const points = [
  {
    title: "One call covers the portfolio",
    description:
      "Turnovers, lock changes, vacant access, inspections, trash-outs, and repairs — coordinated by one crew instead of five vendors.",
  },
  {
    title: "Clear quotes before work starts",
    description:
      "You approve scope and price first. One invoice per job, and B2B locksmith pricing for management companies.",
  },
  {
    title: "Tenant-friendly scheduling",
    description:
      "We coordinate directly with tenants, work from lockboxes, or handle vacant units ourselves — you don't have to be on site.",
  },
];
---

<section id="property-management" class="section-pad scroll-mt-16 overflow-hidden">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16">
    <div class="reveal relative">
      <div class="grid grid-cols-2 gap-4">
        <Image
          src={apartmentBuilding}
          alt="Apartment building with balconies"
          class="row-span-2 h-full w-full rounded-xl object-cover shadow-card"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 24vw, 45vw"
          loading="lazy"
        />
        <Image
          src={basementInterior}
          alt="Clean, rent-ready unit interior"
          class="aspect-[4/3] w-full rounded-xl object-cover shadow-card"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 24vw, 45vw"
          loading="lazy"
        />
        <Image
          src={doorLock}
          alt="Smart lock installed on a unit door"
          class="aspect-[4/3] w-full rounded-xl object-cover shadow-card"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 24vw, 45vw"
          loading="lazy"
        />
      </div>
      <p
        class="bg-kom-field absolute -bottom-5 left-4 rounded-xl px-5 py-3.5 text-white shadow-card-hover sm:left-6"
      >
        <span class="block text-3xl leading-none font-black">5 trades</span>
        <span class="mt-1 block text-xs font-bold tracking-wider text-white/80 uppercase">
          One local crew
        </span>
      </p>
    </div>

    <div class="reveal" style="--rd: 100ms">
      <p class="text-kom-field text-sm font-bold tracking-[0.18em] uppercase">
        Property managers · Landlords · Investors
      </p>
      <h2 class="text-kom-ink mt-2 text-3xl font-black tracking-tight text-balance sm:text-4xl lg:text-[44px] lg:leading-[1.1]">
        The maintenance arm for your rental portfolio.
      </h2>
      <p class="text-muted-foreground mt-4 leading-relaxed">
        {pmServices.join(" · ")} — handled by one team that already knows your properties.
      </p>

      <ol class="mt-8 space-y-6">
        {
          points.map((point, index) => (
            <li class="flex gap-4">
              <span class="text-kom-field/40 text-3xl leading-none font-black" aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="text-kom-ink text-base font-bold">{point.title}</h3>
                <p class="text-muted-foreground mt-1 text-sm leading-relaxed">
                  {point.description}
                </p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/#request-service" variant="primary" size="lg" class="font-bold">
          Request portfolio service
        </Button>
        <Button href={business.phoneHref} variant="outline" size="lg" class="font-bold">
          <Phone aria-hidden="true" />
          Call {business.phone}
        </Button>
      </div>
    </div>
  </div>
</section>
