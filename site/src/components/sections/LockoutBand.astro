---
import { getImage } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";
import MessageCircle from "@tabler/icons/outline/message-circle.svg";

import { business } from "../../data/business";
import bannerImage from "../../assets/images/concrete-work.jpg";

const banner = await getImage({ src: bannerImage, width: 1600, format: "webp" });

/** Every figure below is factual: flyer pricing, county count, trade count. */
const stats = [
  { value: "$129", label: "Standard house / unit unlock" },
  { value: "3", label: "Counties served across Metro Detroit" },
  { value: "5", label: "Trades handled by one crew" },
  { value: "50%", label: "Deposit dispatches a locksmith" },
];
---

<section
  aria-label="Emergency lockout help"
  class="relative bg-kom-ink bg-cover bg-center"
  style={`background-image: url('${banner.src}')`}
>
  <div class="absolute inset-0 bg-kom-ink/85" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20">
    <div class="reveal flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
          Locked out right now?
        </h2>
        <p class="mt-2 max-w-xl text-white/75">
          House and unit unlocks at <a href="/locksmith#pricing" class="text-kom-tan font-bold hover:underline">$129 standard pricing</a> — call or text and we'll dispatch a technician.
        </p>
      </div>
      <p class="flex shrink-0 flex-wrap gap-3">
        <a
          href={business.phoneHref}
          class="bg-kom-field border-b-kom-field-press hover:bg-kom-field-hover inline-flex items-center gap-2 rounded-md border-b-4 px-6 py-3 text-base font-bold text-white transition-colors focus-visible:ring-3 focus-visible:ring-white/40 focus-visible:outline-none"
        >
          <Phone class="size-5" aria-hidden="true" />
          Call {business.phone}
        </a>
        <a
          href={business.smsHref}
          class="inline-flex items-center gap-2 rounded-md border-2 border-white/70 px-6 py-3 text-base font-bold text-white transition-colors hover:bg-white/10 focus-visible:ring-3 focus-visible:ring-white/40 focus-visible:outline-none"
        >
          <MessageCircle class="size-5" aria-hidden="true" />
          Text us
        </a>
      </p>
    </div>

    <dl class="reveal mt-12 grid grid-cols-2 gap-8 border-t border-white/15 pt-10 lg:grid-cols-4" style="--rd: 100ms">
      {
        stats.map((stat) => (
          <div>
            <dt class="sr-only">{stat.label}</dt>
            <dd class="text-4xl font-black text-white sm:text-5xl">{stat.value}</dd>
            <dd class="mt-1.5 text-sm font-medium text-white/70">{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
