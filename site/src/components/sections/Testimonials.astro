---
import Star from "@tabler/icons/outline/star.svg";
import BrandGoogle from "@tabler/icons/outline/brand-google.svg";

import SectionHeader from "../common/SectionHeader.astro";
import { business } from "../../data/business";

/**
 * Layout is ready for Google reviews: fill `rating`/`reviewCount` and the
 * `reviews` array from the real Google Business Profile once reviews exist.
 * Until then the cards are honest placeholders — never invent quotes, names,
 * or star ratings.
 */
const rating: number | null = null;
const reviewCount: number | null = null;

interface Review {
  quote: string;
  name: string;
  detail: string;
}

const reviews: Review[] = [];
const placeholderCount = 3;
---

<section id="reviews" class="section-pad scroll-mt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="What neighbors say"
      lead="We're collecting verified Google reviews from real KOM USA customers — no made-up quotes, ever."
    />

    <div class="reveal mx-auto mt-8 flex max-w-md items-center justify-center gap-3 rounded-xl border bg-kom-cream px-5 py-3.5">
      <BrandGoogle class="text-kom-charcoal size-6 shrink-0" aria-hidden="true" />
      {
        rating ? (
          <p class="text-sm font-bold">
            {rating} on Google
            <span class="text-muted-foreground font-medium">· {reviewCount} reviews</span>
          </p>
        ) : (
          <p class="text-muted-foreground text-sm font-medium">
            Google rating will appear here once our first reviews are in.
          </p>
        )
      }
    </div>

    <ul class="mt-8 grid gap-5 md:grid-cols-3">
      {
        (reviews.length ? reviews : Array.from({ length: placeholderCount })).map(
          (review: Review | undefined, index) => (
            <li
              class="reveal border-border flex flex-col rounded-xl border bg-white p-6 shadow-card"
              style={`--rd: ${index * 80}ms`}
            >
              <span class="text-kom-tan flex gap-1" aria-hidden="true">
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
              </span>
              {review ? (
                <>
                  <p class="text-kom-charcoal/90 mt-3 flex-1 text-sm leading-relaxed">
                    "{review.quote}"
                  </p>
                  <p class="mt-4 flex items-center gap-2.5">
                    <span class="bg-kom-field flex size-9 items-center justify-center rounded-full text-sm font-bold text-white">
                      {review.name.charAt(0)}
                    </span>
                    <span>
                      <span class="text-kom-ink block text-sm font-bold">{review.name}</span>
                      <span class="text-muted-foreground block text-xs">{review.detail}</span>
                    </span>
                  </p>
                </>
              ) : (
                <>
                  <p class="text-muted-foreground mt-3 flex-1 text-sm leading-relaxed">
                    A verified customer review will appear here once it's collected and confirmed.
                  </p>
                  <p class="mt-4 flex items-center gap-2.5">
                    <span class="bg-kom-cream-deep size-9 rounded-full" aria-hidden="true" />
                    <span class="text-muted-foreground text-xs font-bold">
                      Verified review coming soon
                    </span>
                  </p>
                </>
              )}
            </li>
          ),
        )
      }
    </ul>

    <p class="text-muted-foreground mt-8 text-center text-sm">
      Worked with us? We'd love your feedback — call <a href={business.phoneHref} class="text-kom-field font-bold hover:underline">{business.phone}</a> or email <a href={business.emailHref} class="text-kom-field font-bold hover:underline">{business.email}</a>.
    </p>
  </div>
</section>
