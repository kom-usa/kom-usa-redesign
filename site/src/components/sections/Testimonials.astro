---
import Star from "@tabler/icons/outline/star.svg";
import ChevronLeft from "@tabler/icons/outline/chevron-left.svg";
import ChevronRight from "@tabler/icons/outline/chevron-right.svg";

import SectionHeader from "../common/SectionHeader.astro";
import { business } from "../../data/business";

/**
 * No verified customer reviews yet, so these dark cards are honest
 * placeholders styled to match the mockup — never invent quotes. Swap in
 * real, verified reviews (e.g. from Google Business Profile) as collected.
 */
const placeholders = [0, 1, 2];
---

<section id="reviews" class="section-pad scroll-mt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="What neighbors say"
      lead="We're collecting verified reviews from real KOM USA customers and will publish them here — no made-up quotes, ever."
    />

    <div class="mt-12 flex items-center gap-3 sm:gap-4">
      <button
        type="button"
        data-carousel-prev
        aria-label="Previous reviews"
        class="border-kom-ink/20 text-kom-ink hidden size-10 shrink-0 items-center justify-center rounded-full border bg-white/60 transition-colors hover:bg-white focus-visible:ring-3 focus-visible:ring-kom-field focus-visible:outline-none disabled:opacity-40 sm:flex"
      >
        <ChevronLeft class="size-5" aria-hidden="true" />
      </button>

      <ul
        data-carousel-track
        class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 md:pb-0"
        style="scrollbar-width: none"
      >
        {
          placeholders.map((index) => (
            <li
              class="reveal bg-kom-ink flex min-w-[85%] snap-start flex-col rounded-xl p-6 sm:min-w-[48%] md:min-w-0 md:flex-1"
              style={`--rd: ${index * 80}ms`}
            >
              <span class="border-kom-tan/50 text-kom-tan inline-flex self-start rounded-full border px-3 py-0.5 text-xs font-bold">
                Verified review coming soon
              </span>
              <span class="text-kom-tan mt-4 flex gap-1" aria-hidden="true">
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
                <Star class="size-4.5" />
              </span>
              <p class="mt-3 text-sm leading-relaxed text-white/70">
                A verified customer review will appear here once it's collected and confirmed.
              </p>
              <p class="mt-4 text-sm font-bold text-white/50">— Your neighbor in Metro Detroit</p>
            </li>
          ))
        }
      </ul>

      <button
        type="button"
        data-carousel-next
        aria-label="Next reviews"
        class="border-kom-ink/20 text-kom-ink hidden size-10 shrink-0 items-center justify-center rounded-full border bg-white/60 transition-colors hover:bg-white focus-visible:ring-3 focus-visible:ring-kom-field focus-visible:outline-none disabled:opacity-40 sm:flex"
      >
        <ChevronRight class="size-5" aria-hidden="true" />
      </button>
    </div>

    <p class="text-muted-foreground mt-8 text-center text-sm">
      Worked with us? We'd love your feedback — call <a href={business.phoneHref} class="text-kom-field font-bold hover:underline">{business.phone}</a> or email <a href={business.emailHref} class="text-kom-field font-bold hover:underline">{business.email}</a>.
    </p>
  </div>

  <script>
    // Simple carousel controls: scroll the track by one card, disable arrows
    // at the ends. The track is a plain scroll container without JS.
    const section = document.getElementById("reviews");
    const track = section?.querySelector<HTMLElement>("[data-carousel-track]");
    const prev = section?.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = section?.querySelector<HTMLButtonElement>("[data-carousel-next]");

    if (track && prev && next) {
      const cardWidth = () =>
        (track.firstElementChild as HTMLElement | null)?.offsetWidth ?? track.clientWidth;

      const update = () => {
        const maxScroll = track.scrollWidth - track.clientWidth;
        prev.disabled = track.scrollLeft <= 4;
        next.disabled = track.scrollLeft >= maxScroll - 4;
        const scrollable = maxScroll > 8;
        prev.classList.toggle("sm:flex", scrollable);
        prev.classList.toggle("sm:hidden", !scrollable);
        next.classList.toggle("sm:flex", scrollable);
        next.classList.toggle("sm:hidden", !scrollable);
      };

      prev.addEventListener("click", () => track.scrollBy({ left: -cardWidth(), behavior: "smooth" }));
      next.addEventListener("click", () => track.scrollBy({ left: cardWidth(), behavior: "smooth" }));
      track.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
      update();
    }
  </script>
</section>
