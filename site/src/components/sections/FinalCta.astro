---
import Phone from "@tabler/icons/outline/phone.svg";

import Button from "../starwind/button/Button.astro";
import Roofline from "../common/Roofline.astro";
import { business } from "../../data/business";
---

<section class="bg-kom-charcoal-deep">
  <div class="reveal mx-auto flex max-w-6xl flex-col items-center px-4 py-16 text-center sm:px-6 md:py-20">
    <Roofline class="text-kom-sage" />
    <h2 class="mt-5 max-w-2xl text-3xl font-extrabold text-balance text-white sm:text-4xl">
      One call covers your home, your rental, and everything on the list.
    </h2>
    <p class="mt-4 max-w-xl text-lg text-white/70">
      Construction, maintenance, locksmith, and chimney care across Metro Detroit.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href={business.phoneHref} variant="primary" size="lg" class="font-bold">
        <Phone aria-hidden="true" />
        Call {business.phone}
      </Button>
      <Button
        href="#request-service"
        size="lg"
        class="border border-white/25 bg-transparent font-bold text-white hover:bg-white/10 focus-visible:ring-white/40"
      >
        Request service
      </Button>
    </div>
  </div>
</section>
