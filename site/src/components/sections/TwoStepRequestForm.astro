---
import Phone from "@tabler/icons/outline/phone.svg";
import ClipboardCheck from "@tabler/icons/outline/clipboard-check.svg";
import PhoneCall from "@tabler/icons/outline/phone-call.svg";
import Check from "@tabler/icons/outline/check.svg";
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import ArrowLeft from "@tabler/icons/outline/arrow-left.svg";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
import Label from "../ui/Label.astro";
import Textarea from "../ui/Textarea.astro";

interface Props {
  line?: "maintenance" | "construction" | "";
}
const { line = "" } = Astro.props;

const steps = [
  { icon: Phone, text: "Share some info and the local KOM USA team will contact you." },
  { icon: ClipboardCheck, text: "Choose Maintenance or Construction and describe the project." },
  { icon: PhoneCall, text: "Either way, we will call you to discuss your request and answer questions." },
];

const errClass = "step-error text-error mt-1 hidden text-xs font-semibold";
const invalidClass = "aria-[invalid=true]:border-error";
---

<section id="request-form" class="scroll-mt-28" data-two-step-root>
  <div class="rounded-2xl border border-kom-charcoal/10 bg-white p-6 shadow-card sm:p-10">
    <ol class="grid gap-4 sm:grid-cols-3">
      {steps.map((step) => (
        <li class="relative rounded-xl bg-kom-sage-tint px-5 pt-9 pb-5 text-center text-sm font-bold leading-relaxed text-kom-charcoal">
          <span class="absolute -top-5 left-1/2 flex size-10 -translate-x-1/2 items-center justify-center rounded-full bg-kom-field text-white shadow-sm"><step.icon class="size-5" aria-hidden="true" /></span>
          {step.text}
        </li>
      ))}
    </ol>

    <div class="mx-auto mt-9 flex max-w-md items-center" aria-hidden="true" data-progress>
      <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-kom-field font-black text-white" data-progress-dot="1">1</span>
      <span class="h-1 flex-1 rounded bg-kom-concrete" data-progress-bar></span>
      <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-kom-concrete font-black text-kom-charcoal/60" data-progress-dot="2">2</span>
    </div>
    <p class="sr-only" role="status" data-step-status>Step 1 of 2</p>

    <form
      name="request-service"
      method="POST"
      action="/thank-you/"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="two-step-request-form mt-8"
      data-default-line={line}
      novalidate={false}
    >
      <input type="hidden" name="form-name" value="request-service" />
      <input type="hidden" name="subject" value="New service or estimate request — kom-usa.com" />
      <input type="hidden" name="name" value="" data-full-name />
      <input type="hidden" name="service" value="" data-service-label />
      <input type="hidden" name="source-page-url" value="" data-source-url />
      <input type="hidden" name="utm-source" value="" data-utm="utm_source" />
      <input type="hidden" name="utm-medium" value="" data-utm="utm_medium" />
      <input type="hidden" name="utm-campaign" value="" data-utm="utm_campaign" />
      <input type="hidden" name="utm-term" value="" data-utm="utm_term" />
      <input type="hidden" name="utm-content" value="" data-utm="utm_content" />
      <p class="hidden" aria-hidden="true"><label>Leave this field empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

      <fieldset data-step-panel="1">
        <legend class="mx-auto text-center text-2xl font-black text-kom-charcoal-deep sm:text-3xl">How can we reach you?</legend>
        <p class="mt-2 text-center text-sm text-kom-charcoal/65"><span class="text-error">*</span> indicates a required field</p>
        <div class="mx-auto mt-7 grid max-w-2xl gap-x-6 gap-y-5 sm:grid-cols-2">
          <div class="space-y-2">
            <Label for="req-first-name">First name <span class="text-error">*</span></Label>
            <Input id="req-first-name" name="first-name" type="text" required autocomplete="given-name" placeholder="e.g. Sam" aria-describedby="req-first-name-error" class={invalidClass} />
            <p id="req-first-name-error" class={errClass} role="alert">Please enter your first name.</p>
          </div>
          <div class="space-y-2">
            <Label for="req-last-name">Last name <span class="text-error">*</span></Label>
            <Input id="req-last-name" name="last-name" type="text" required autocomplete="family-name" placeholder="e.g. Miller" aria-describedby="req-last-name-error" class={invalidClass} />
            <p id="req-last-name-error" class={errClass} role="alert">Please enter your last name.</p>
          </div>
          <div class="space-y-2">
            <Label for="req-zip">ZIP code <span class="text-error">*</span></Label>
            <Input id="req-zip" name="city" type="text" required inputmode="numeric" autocomplete="postal-code" placeholder="e.g. 48088" aria-describedby="req-zip-error" class={invalidClass} />
            <p id="req-zip-error" class={errClass} role="alert">Enter the ZIP code for the property.</p>
          </div>
          <div class="space-y-2">
            <Label for="req-address">Street address <span class="text-error">*</span></Label>
            <Input id="req-address" name="street-address" type="text" required autocomplete="street-address" placeholder="e.g. 123 Main St" aria-describedby="req-address-error" class={invalidClass} />
            <p id="req-address-error" class={errClass} role="alert">Enter the street address.</p>
          </div>
          <div class="space-y-2 sm:col-span-2">
            <Label for="req-apt">Apt, suite, unit, etc. <span class="font-normal text-kom-charcoal/60">(optional)</span></Label>
            <Input id="req-apt" name="apt-suite" type="text" placeholder="e.g. Apt 123, Suite A" />
          </div>
          <div class="space-y-2">
            <Label for="req-email">Email <span class="text-error">*</span></Label>
            <Input id="req-email" name="email" type="email" required autocomplete="email" placeholder="you@email.com" aria-describedby="req-email-error" class={invalidClass} />
            <p id="req-email-error" class={errClass} role="alert">Enter a valid email address.</p>
          </div>
          <div class="space-y-2">
            <Label for="req-phone">Phone number <span class="text-error">*</span></Label>
            <Input id="req-phone" name="phone" type="tel" required autocomplete="tel" inputmode="tel" placeholder="(555) 555-5555" aria-describedby="req-phone-error" class={invalidClass} />
            <p id="req-phone-error" class={errClass} role="alert">Enter a phone number we can reach you at.</p>
          </div>
        </div>
        <div class="mx-auto mt-7 max-w-2xl">
          <Button type="button" variant="primary" size="lg" class="step-continue w-full sm:w-auto" data-continue>
            Continue
            <ArrowRight class="size-5" aria-hidden="true" />
          </Button>
        </div>
      </fieldset>

      <fieldset class="hidden" data-step-panel="2">
        <legend class="mx-auto text-center text-2xl font-black text-kom-charcoal-deep sm:text-3xl">Tell us more about your request</legend>
        <p class="mt-2 text-center text-sm text-kom-charcoal/65"><span class="text-error">*</span> indicates a required field</p>
        <div class="mx-auto mt-7 max-w-2xl">
          <span class="block font-bold text-kom-charcoal-deep" id="req-line-label">Select service type <span class="text-error">*</span></span>
          <div class="mt-3 grid gap-3 sm:grid-cols-2" role="radiogroup" aria-labelledby="req-line-label" aria-describedby="req-line-error">
            <label class="flex cursor-pointer items-center gap-3 rounded-xl border-2 border-kom-charcoal/15 bg-white p-4 font-extrabold text-kom-charcoal-deep transition-colors has-checked:border-kom-field has-checked:bg-kom-sage-tint">
              <input type="radio" name="service-line" value="maintenance" required checked={line === "maintenance"} class="size-5 accent-kom-field" data-line-radio data-line-label="Maintenance" />
              <span>Maintenance<span class="mt-0.5 block text-xs font-semibold text-kom-charcoal/65">Repairs, upkeep, and handyman work</span></span>
            </label>
            <label class="flex cursor-pointer items-center gap-3 rounded-xl border-2 border-kom-charcoal/15 bg-white p-4 font-extrabold text-kom-charcoal-deep transition-colors has-checked:border-kom-field has-checked:bg-kom-sage-tint">
              <input type="radio" name="service-line" value="construction" required checked={line === "construction"} class="size-5 accent-kom-field" data-line-radio data-line-label="Construction" />
              <span>Construction<span class="mt-0.5 block text-xs font-semibold text-kom-charcoal/65">Remodeling, building, and larger projects</span></span>
            </label>
          </div>
          <p id="req-line-error" class={errClass} role="alert">Choose Maintenance or Construction.</p>

          <div class="mt-6 space-y-2">
            <Label for="req-message">Describe your project <span class="font-normal text-kom-charcoal/60">(optional)</span></Label>
            <Textarea id="req-message" name="message" rows={5} placeholder="Help us understand what needs attention — include quantities, dimensions, access details, or project goals when you can." />
          </div>

          <p class="mt-6 max-w-3xl text-xs leading-relaxed text-kom-charcoal/70">
            By submitting, you consent to KOM USA contacting you about this service request. This form does not add you to a marketing list.
          </p>
          <div class="mt-5 flex flex-col-reverse items-stretch gap-3 sm:flex-row sm:items-center">
            <button type="button" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md px-5 font-extrabold text-kom-field transition-colors hover:bg-kom-sage-tint focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-kom-field/40" data-back>
              <ArrowLeft class="size-5" aria-hidden="true" />
              Back
            </button>
            <Button type="submit" variant="primary" size="lg" data-request-submit>
              Submit Request
              <Check class="size-5" aria-hidden="true" />
            </Button>
          </div>
        </div>
      </fieldset>
    </form>
  </div>
</section>

<style>
  /* Without JavaScript both panels stay visible and the form submits in one pass,
     so the step controls only make sense when JS is running. */
  html:not(.js) [data-step-panel="2"] {
    display: block !important;
  }
  html:not(.js) [data-continue],
  html:not(.js) [data-back],
  html:not(.js) [data-progress] {
    display: none !important;
  }
</style>

<script>
  const EMAIL = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const dataLayer = () => ((window as typeof window & { dataLayer?: Record<string, unknown>[] }).dataLayer ??= []);

  document.querySelectorAll<HTMLElement>("[data-two-step-root]").forEach((root) => {
    const form = root.querySelector<HTMLFormElement>("form.two-step-request-form");
    if (!form) return;
    form.noValidate = true;

    const panel1 = form.querySelector<HTMLElement>('[data-step-panel="1"]');
    const panel2 = form.querySelector<HTMLElement>('[data-step-panel="2"]');
    const dot2 = root.querySelector<HTMLElement>('[data-progress-dot="2"]');
    const bar = root.querySelector<HTMLElement>("[data-progress-bar]");
    const status = root.querySelector<HTMLElement>("[data-step-status]");
    const submitBtn = form.querySelector<HTMLButtonElement>("[data-request-submit]");

    const STEP1_REQUIRED = ["first-name", "last-name", "city", "street-address", "email", "phone"];
    const field = (name: string) => form.querySelector<HTMLInputElement>(`[name="${name}"]:not([type="hidden"])`);

    const validate = (el: HTMLInputElement) => {
      const value = (el.value || "").trim();
      let ok = value !== "";
      if (ok && el.type === "email") ok = EMAIL.test(value);
      if (ok && el.type === "tel") ok = value.replace(/\D/g, "").length >= 7;
      el.setAttribute("aria-invalid", ok ? "false" : "true");
      const err = el.getAttribute("aria-describedby");
      if (err) form.querySelector(`#${err}`)?.classList.toggle("hidden", ok);
      return ok;
    };

    for (const name of STEP1_REQUIRED) {
      const el = field(name);
      if (!el) continue;
      el.addEventListener("blur", () => validate(el));
      el.addEventListener("input", () => {
        if (el.getAttribute("aria-invalid") === "true") validate(el);
      });
    }

    const validateStep1 = () => {
      let firstInvalid: HTMLInputElement | null = null;
      for (const name of STEP1_REQUIRED) {
        const el = field(name);
        if (el && !validate(el) && !firstInvalid) firstInvalid = el;
      }
      if (firstInvalid) {
        firstInvalid.focus();
        firstInvalid.scrollIntoView({ block: "center", behavior: "smooth" });
      }
      return !firstInvalid;
    };

    const setStep = (step: 1 | 2) => {
      panel1?.classList.toggle("hidden", step !== 1);
      panel2?.classList.toggle("hidden", step !== 2);
      dot2?.classList.toggle("bg-kom-field", step === 2);
      dot2?.classList.toggle("text-white", step === 2);
      dot2?.classList.toggle("bg-kom-concrete", step !== 2);
      dot2?.classList.toggle("text-kom-charcoal/60", step !== 2);
      if (bar) bar.style.background = step === 2 ? "var(--color-kom-field)" : "var(--color-kom-concrete)";
      if (status) status.textContent = `Step ${step} of 2`;
      root.scrollIntoView({ block: "start", behavior: "smooth" });
    };

    form.querySelector("[data-continue]")?.addEventListener("click", () => {
      if (!validateStep1()) return;
      setStep(2);
      panel2?.querySelector<HTMLInputElement>("[data-line-radio]")?.focus();
      dataLayer().push({ event: "form_step_complete", form_name: "request-service", step: 1 });
    });
    form.querySelector("[data-back]")?.addEventListener("click", () => setStep(1));

    // Preselect from ?line= links and sync tracking fields.
    const params = new URLSearchParams(window.location.search);
    const requestedLine = params.get("line") || form.dataset.defaultLine || "";
    if (["maintenance", "construction"].includes(requestedLine)) {
      const radio = form.querySelector<HTMLInputElement>(`[data-line-radio][value="${requestedLine}"]`);
      if (radio) radio.checked = true;
    }
    const sourceUrl = form.querySelector<HTMLInputElement>("[data-source-url]");
    if (sourceUrl) sourceUrl.value = window.location.href;
    form.querySelectorAll<HTMLInputElement>("[data-utm]").forEach((el) => {
      el.value = params.get(el.dataset.utm || "") || "";
    });

    let started = false;
    form.addEventListener("focusin", () => {
      if (started) return;
      started = true;
      dataLayer().push({ event: "form_start", form_name: "request-service", source_page: window.location.pathname });
    });

    form.addEventListener("submit", (event) => {
      const checked = form.querySelector<HTMLInputElement>("[data-line-radio]:checked");
      if (!checked) {
        event.preventDefault();
        setStep(2);
        form.querySelector("#req-line-error")?.classList.remove("hidden");
        return;
      }
      form.querySelector("#req-line-error")?.classList.add("hidden");

      const fullName = form.querySelector<HTMLInputElement>("[data-full-name]");
      if (fullName) fullName.value = [field("first-name")?.value, field("last-name")?.value].map((v) => (v || "").trim()).filter(Boolean).join(" ");
      const serviceLabel = form.querySelector<HTMLInputElement>("[data-service-label]");
      if (serviceLabel) serviceLabel.value = checked.dataset.lineLabel || "";

      sessionStorage.setItem("kom-request-confirmation", JSON.stringify({ service: checked.dataset.lineLabel || "your request", line: checked.value }));
      dataLayer().push({ event: "form_complete", form_name: "request-service", service_line: checked.value, source_page: window.location.pathname });
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";
      }
    });
  });
</script>
