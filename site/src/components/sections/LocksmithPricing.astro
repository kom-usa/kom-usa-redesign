---
import { Image } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";

import { business, locksmithNotes, locksmithPricing } from "../../data/business";
import doorLock from "../../assets/images/door-lock.jpg";
---

<section id="locksmith-pricing" class="section-pad scroll-mt-16">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="reveal bg-kom-field-deep relative overflow-hidden rounded-2xl p-6 sm:p-10">
      <h2 class="font-serif text-center text-3xl font-bold text-white sm:text-4xl">
        Transparent Pricing
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-center text-sm leading-relaxed text-white/75">
        Standard locksmith pricing for Metro Detroit homes, units, and rentals — published upfront.
        Final pricing may vary based on lock hardware, door condition, and service details.
      </p>

      <div class="mt-8 grid items-start gap-6 md:grid-cols-[1fr_200px]">
        <div class="overflow-hidden rounded-lg">
          <table class="w-full text-left">
            <caption class="sr-only">Locksmith services standard pricing</caption>
            <thead>
              <tr class="bg-kom-tan-light text-kom-ink">
                <th scope="col" class="px-5 py-3 text-sm font-bold">Service</th>
                <th scope="col" class="px-5 py-3 text-right text-sm font-bold">Standard price</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-kom-cream-deep bg-white/95">
              {
                locksmithPricing.map((item) => (
                  <tr>
                    <td class="px-5 py-3">
                      <p class="text-kom-ink text-sm font-bold">{item.service}</p>
                      {item.detail && (
                        <p class="text-muted-foreground mt-0.5 text-xs">{item.detail}</p>
                      )}
                    </td>
                    <td class="text-kom-field px-5 py-3 text-right text-base font-extrabold whitespace-nowrap">
                      {item.price}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <div class="hidden md:block">
          <Image
            src={doorLock}
            alt="Kwikset-style smart keypad on a unit door (stock photo)"
            class="aspect-[3/4] w-full rounded-lg object-cover"
            widths={[400]}
            sizes="200px"
            loading="lazy"
          />
          <p class="mt-3 text-xs leading-relaxed text-white/75">
            Smart keypads for modern property access — keyless entry, user codes, and audit trails
            on select models.
          </p>
        </div>
      </div>

      <ul class="mt-6 space-y-1.5 text-xs leading-relaxed text-white/75">
        {locksmithNotes.map((note) => <li>{note}</li>)}
      </ul>

      <p class="mt-6 text-center">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-md bg-white px-5 py-2.5 text-sm font-bold text-kom-field transition-colors hover:bg-white/90 focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none"
        >
          <Phone class="size-4" aria-hidden="true" />
          Locked out? Call {business.phone}
        </a>
      </p>
    </div>
  </div>
</section>
