---
import Icon from "../common/Icon.astro";
import { trustPoints } from "../../data/business";

const features = [
  ...trustPoints,
  {
    title: "Plain communication",
    description: "You know what happens next, what it costs, and who to call.",
    icon: "message-circle",
  },
];
---

<section class="section-pad bg-white">
  <div class="mx-auto max-w-7xl px-4 text-center sm:px-6">
    <div class="reveal mx-auto max-w-3xl">
      <h2 class="text-kom-charcoal-deep text-3xl font-black tracking-tight text-balance sm:text-4xl lg:text-[44px] lg:leading-[1.1]">
        Why choose <span class="text-kom-field">KOM USA?</span>
      </h2>
      <p class="text-muted-foreground mt-4 text-base leading-relaxed">
        The polished service experience of a larger company, with the local responsiveness of one
        Metro Detroit crew.
      </p>
    </div>

    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
      {
        features.map((feature, index) => (
          <li class="reveal flex flex-col items-center" style={`--rd: ${index * 65}ms`}>
            <span class="border-kom-field/15 text-kom-field flex size-16 items-center justify-center rounded-full border-2 bg-kom-sage-tint">
              <Icon name={feature.icon} class="size-7" />
            </span>
            <h3 class="text-kom-charcoal-deep mt-5 text-base font-black">{feature.title}</h3>
            <p class="text-muted-foreground mt-2 max-w-52 text-sm leading-relaxed">
              {feature.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
