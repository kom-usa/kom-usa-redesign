---
import { getImage } from "astro:assets";
import Phone from "@tabler/icons/outline/phone.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import Key from "@tabler/icons/outline/key.svg";
import BuildingCommunity from "@tabler/icons/outline/building-community.svg";
import Clock from "@tabler/icons/outline/clock.svg";

import Button from "../starwind/button/Button.astro";
import { business } from "../../data/business";
import bannerImage from "../../assets/images/construction-framing.jpg";

/**
 * Full-bleed jobsite banner with a dark overlay and a big left-aligned
 * headline. Trust chips: "Licensed & insured" stays absent until the owner
 * confirms it's accurate.
 */
const banner = await getImage({ src: bannerImage, width: 1920, format: "webp" });

const chips = [
  { label: "Metro Detroit local", icon: MapPin },
  { label: "Upfront locksmith pricing", icon: Key, href: "/locksmith#pricing" },
  { label: "Property-manager friendly", icon: BuildingCommunity },
  { label: "Fast response", icon: Clock },
];
---

<section
  class="relative bg-kom-ink bg-cover bg-center"
  style={`background-image: url('${banner.src}')`}
>
  <div class="absolute inset-0 bg-kom-ink/70" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl px-4 pt-20 pb-24 sm:px-6 lg:pt-28 lg:pb-32">
    <div class="reveal max-w-3xl">
      <p class="text-kom-sage text-sm font-bold tracking-[0.18em] uppercase">
        One local crew · Metro Detroit
      </p>
      <h1 class="mt-4 text-4xl font-black text-balance text-white sm:text-5xl lg:text-[64px] lg:leading-[1.06] lg:tracking-tight">
        Construction, maintenance, locksmith, and turnover help across Metro Detroit.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80 sm:text-xl">
        One local crew for homeowners, landlords, and property managers across Wayne, Oakland,
        and Macomb counties.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Button href="/#request-service" variant="primary" size="lg" class="font-bold">
          Request service
        </Button>
        <Button
          href={business.phoneHref}
          size="lg"
          class="border-2 border-white/70 bg-transparent font-bold text-white hover:bg-white/10 focus-visible:ring-white/40"
        >
          <Phone aria-hidden="true" />
          Call now
        </Button>
      </div>

      <ul class="mt-10 flex flex-wrap gap-2.5">
        {
          chips.map((chip) => {
            const Tag = chip.href ? "a" : "span";
            return (
              <li class="contents">
                <Tag
                  href={chip.href}
                  class:list={[
                    "flex items-center gap-1.5 rounded-full border border-white/25 bg-white/10 px-3.5 py-1.5 text-xs font-bold text-white",
                    chip.href &&
                      "transition-colors hover:border-kom-sage hover:text-kom-sage focus-visible:ring-3 focus-visible:ring-white/40 focus-visible:outline-none",
                  ]}
                >
                  <chip.icon class="text-kom-sage size-3.5" aria-hidden="true" />
                  {chip.label}
                </Tag>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>
