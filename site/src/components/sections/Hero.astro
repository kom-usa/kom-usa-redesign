---
import { Image } from "astro:assets";
import StarFilled from "@tabler/icons/filled/star.svg";
import Phone from "@tabler/icons/outline/phone.svg";

import Button from "../starwind/button/Button.astro";
import LeadCallForm from "./LeadCallForm.astro";
import { business, googleReviews } from "../../data/business";
import doorLock from "../../assets/images/door-lock.jpg";
---

<section class="relative">
  <div class="relative isolate overflow-hidden bg-kom-ink pb-40 lg:pb-48">
    <Image
      src={doorLock}
      alt=""
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 -z-10 bg-kom-ink/72" aria-hidden="true"></div>

    <div class="mx-auto max-w-7xl px-4 pt-16 pb-10 sm:px-6 lg:pt-24">
      <div class="max-w-2xl">
        <p class="text-kom-tan text-base font-extrabold sm:text-lg">Maintenance experts you can trust</p>
        <h1 class="mt-3 text-4xl leading-[1.03] font-black tracking-tight text-white text-balance sm:text-5xl lg:text-6xl">
          A friendly local crew for<br class="hidden sm:block" /> locks, water heaters & chimneys
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/85">
          A small, locally owned Metro Detroit team. Tell us what you need, we'll
          call you back, talk it through, and take care of it — with our standard
          prices published right here.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4 sm:gap-5">
          <a
            href={googleReviews.url}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-3 rounded-lg border border-white/15 bg-white/10 px-4 py-2.5 transition-colors hover:bg-white/20 focus-visible:ring-3 focus-visible:ring-white/50 focus-visible:outline-none"
          >
            <span class="text-3xl font-black text-white">{googleReviews.rating}</span>
            <span>
              <span class="flex text-kom-brass" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => <StarFilled class="size-4" />)}
              </span>
              <span class="block text-xs font-bold text-white/85">
                {googleReviews.count} Google reviews
              </span>
            </span>
          </a>
          <Button href={business.phoneHref} variant="outline" size="lg" class="border-white/50 bg-transparent font-extrabold text-white hover:bg-white/10 hover:text-white">
            <Phone aria-hidden="true" />
            {business.phone}
          </Button>
          <p class="flex items-center gap-2 text-sm font-bold text-white/80">
            <span class="bg-kom-sage inline-block size-2 rounded-full" aria-hidden="true"></span>
            Licensed & insured · Same-day callback
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto -mt-32 max-w-6xl px-4 sm:px-6 lg:-mt-36">
    <div class="reveal" style="--rd: 120ms">
      <LeadCallForm />
    </div>
  </div>
</section>
