---
import MapPin from "@tabler/icons/outline/map-pin.svg";

import SectionHeader from "../common/SectionHeader.astro";
import Roofline from "../common/Roofline.astro";
import { business, serviceAreaCities, serviceAreaCounties } from "../../data/business";
import { getLocations } from "../../lib/sanity";

const countiesSentence = serviceAreaCounties.join(", ").replace(/, ([^,]*)$/, ", and $1");

// Location pages exist per city in Sanity; linking each chip back to its page
// keeps internal links flowing to the location content for SEO.
const locations = await getLocations();
const locationPath = (city: string) => {
  const match = locations.find((location) => location.city.toLowerCase() === city.toLowerCase());
  return match ? `/locations/${match.slug}/` : undefined;
};

// Google Map of the service area. With an API key we use the official Maps
// Embed API (pin on the KOM USA listing); without one we fall back to the
// keyless embed so the build never ships a broken map.
const embedKey = import.meta.env.GOOGLE_MAPS_EMBED_KEY ?? import.meta.env.GOOGLE_MAPS_API_KEY;
const mapSrc = embedKey
  ? `https://www.google.com/maps/embed/v1/place?key=${embedKey}&q=${encodeURIComponent("KOM USA, Metro Detroit, MI")}&center=42.383,-83.102&zoom=9`
  : "https://maps.google.com/maps?ll=42.383,-83.102&z=9&output=embed";
---

<section id="service-area" class="section-pad scroll-mt-16 bg-kom-cream">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="Our Service Area"
      lead={`Based in Metro Detroit and working across it — serving homes throughout ${countiesSentence}.`}
    />

    <div class="mt-12 grid items-stretch gap-6 lg:grid-cols-2">
      <div class="reveal border-border overflow-hidden rounded-xl border bg-white shadow-card">
        <iframe
          src={mapSrc}
          title="Google Map of the KOM USA service area across Metro Detroit"
          class="h-full min-h-80 w-full border-0"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>

      <div class="reveal flex flex-col justify-center" style="--rd: 100ms">
        <ul class="flex flex-wrap gap-2.5">
          {
            serviceAreaCities.map((city) => {
              const href = locationPath(city);
              return (
                <li>
                  {href ? (
                    <a href={href} class="border-border text-kom-ink hover:border-kom-field/40 hover:text-kom-field flex items-center gap-1.5 rounded-full border bg-white px-3.5 py-1.5 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-field/40">
                      <MapPin class="text-kom-field size-3.5" aria-hidden="true" />
                      {city}
                    </a>
                  ) : (
                    <span class="border-border text-kom-ink flex items-center gap-1.5 rounded-full border bg-white px-3.5 py-1.5 text-sm font-medium">
                      <MapPin class="text-kom-field size-3.5" aria-hidden="true" />
                      {city}
                    </span>
                  )}
                </li>
              );
            })
          }
          <li class="text-muted-foreground flex items-center px-2 py-1.5 text-sm font-medium">
            …and surrounding Metro Detroit communities
          </li>
        </ul>

        <Roofline class="text-kom-tan mt-8" />
        <p class="text-muted-foreground mt-4 max-w-xl text-sm leading-relaxed">
          Not sure whether a property or job site is in range? Include the city or ZIP in your request, call <a href={business.maintenancePhoneHref} class="text-kom-field font-bold hover:underline">Maintenance at {business.maintenancePhone}</a>, or call <a href={business.constructionPhoneHref} class="text-kom-field font-bold hover:underline">Construction at {business.constructionPhone}</a>.
        </p>
      </div>
    </div>
  </div>
</section>
