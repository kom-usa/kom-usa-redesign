---
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import Phone from "@tabler/icons/outline/phone.svg";

import { business } from "../../data/business";
import { featuredServiceAreas } from "../../data/service-areas";

const embedKey = import.meta.env.GOOGLE_MAPS_EMBED_KEY ?? import.meta.env.GOOGLE_MAPS_API_KEY;
const mapSrc = embedKey
  ? `https://www.google.com/maps/embed/v1/view?key=${embedKey}&center=42.383,-83.102&zoom=9&maptype=roadmap`
  : "https://maps.google.com/maps?ll=42.383,-83.102&z=9&output=embed";
---

<section id="service-area" class="section-pad scroll-mt-16 bg-kom-charcoal-deep text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-start gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
      <div>
        <p class="inline-flex items-center gap-2 text-sm font-extrabold text-kom-sage">
          <MapPin class="size-5" aria-hidden="true" />
          Local to Metro Detroit
        </p>
        <h2 class="mt-4 max-w-2xl text-4xl font-black tracking-[-0.035em] text-white text-balance sm:text-5xl">
          Serving all of Metro Detroit.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/75">
          If your home, rental, or project is in Metro Detroit, start with KOM USA. The local pages below are helpful starting points—not the edge of our service area.
        </p>

        <ul class="mt-9 grid border-t border-white/15 sm:grid-cols-2">
          {featuredServiceAreas.map((area) => (
            <li class="border-b border-white/15 sm:odd:pr-4 sm:even:pl-4">
              <a
                href={`/service-areas/${area.slug}/`}
                class="group flex min-h-13 items-center justify-between gap-3 py-3 font-extrabold text-white transition-colors hover:text-kom-sage focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kom-sage"
              >
                <span>{area.city}</span>
                <ArrowRight class="size-4 shrink-0 transition-transform group-hover:translate-x-1" aria-hidden="true" />
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/service-areas/" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-white px-6 font-extrabold text-kom-field transition-colors hover:bg-kom-warm-white">
            Explore our service area
            <ArrowRight class="size-4" aria-hidden="true" />
          </a>
          <a href={business.maintenancePhoneHref} class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border-2 border-white/35 px-6 font-extrabold text-white transition-colors hover:border-white hover:bg-white/10">
            <Phone class="size-5" aria-hidden="true" />
            Check your location
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-xl bg-white shadow-lg">
        <iframe
          src={mapSrc}
          title="Map centered on the KOM USA Metro Detroit service area"
          class="h-[28rem] w-full border-0 lg:h-[36rem]"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"></iframe>
        <div class="bg-white p-5 text-kom-charcoal">
          <p class="font-black text-kom-charcoal-deep">Not sure whether your address is covered?</p>
          <p class="mt-1 text-sm leading-relaxed text-kom-charcoal/70">Send the city or ZIP with your project details. We will confirm travel and timing before anything is scheduled.</p>
        </div>
      </div>
    </div>
  </div>
</section>
