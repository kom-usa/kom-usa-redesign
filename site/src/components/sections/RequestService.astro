---
import Phone from "@tabler/icons/outline/phone.svg";
import Mail from "@tabler/icons/outline/mail.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import ChevronDown from "@tabler/icons/outline/chevron-down.svg";

import Button from "../starwind/button/Button.astro";
import Input from "../starwind/input/Input.astro";
import Label from "../starwind/label/Label.astro";
import Textarea from "../starwind/textarea/Textarea.astro";
import SectionHeader from "../common/SectionHeader.astro";
import { business, serviceOptions, urgencyOptions } from "../../data/business";

/**
 * Netlify Forms: this is a plain HTML form on a static page, so Netlify's build
 * parser registers it automatically from `data-netlify`. Enable form detection
 * in the Netlify UI (Forms section) before launch. ServiceM8 booking replaces
 * or augments this in a later phase.
 */
const selectClass =
  "border-input focus-visible:outline-outline flex h-11 w-full rounded-md border bg-white px-3 py-1 text-base transition-colors focus-visible:outline-2 focus-visible:outline-offset-1";
---

<section id="request-service" class="section-pad scroll-mt-16 bg-kom-cream">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      eyebrow="Request service"
      title="Tell us what you need. We'll take it from there."
      lead="Send a few details and we'll follow up with a quote and scheduling. Locked out right now? Skip the form and call."
    />

    <div class="mt-12 grid gap-8 lg:grid-cols-[1fr_1.6fr]">
      <div class="reveal flex flex-col gap-4 self-start">
        <a
          href={business.phoneHref}
          class="border-border group flex items-center gap-4 rounded-lg border bg-white p-5 shadow-card transition-shadow hover:shadow-card-hover focus-visible:ring-3 focus-visible:ring-primary/50 focus-visible:outline-none"
        >
          <span class="bg-kom-sage-tint text-primary flex size-12 shrink-0 items-center justify-center rounded-lg">
            <Phone class="size-6" aria-hidden="true" />
          </span>
          <span>
            <span class="text-muted-foreground block text-xs font-bold tracking-wider uppercase">Call us</span>
            <span class="text-kom-charcoal group-hover:text-primary block text-lg font-extrabold transition-colors">
              {business.phone}
            </span>
          </span>
        </a>
        <a
          href={business.emailHref}
          class="border-border group flex items-center gap-4 rounded-lg border bg-white p-5 shadow-card transition-shadow hover:shadow-card-hover focus-visible:ring-3 focus-visible:ring-primary/50 focus-visible:outline-none"
        >
          <span class="bg-kom-sage-tint text-primary flex size-12 shrink-0 items-center justify-center rounded-lg">
            <Mail class="size-6" aria-hidden="true" />
          </span>
          <span>
            <span class="text-muted-foreground block text-xs font-bold tracking-wider uppercase">Email us</span>
            <span class="text-kom-charcoal group-hover:text-primary block text-lg font-extrabold transition-colors">
              {business.email}
            </span>
          </span>
        </a>
        <div class="border-border flex items-center gap-4 rounded-lg border bg-white p-5 shadow-card">
          <span class="bg-kom-sage-tint text-primary flex size-12 shrink-0 items-center justify-center rounded-lg">
            <MapPin class="size-6" aria-hidden="true" />
          </span>
          <span>
            <span class="text-muted-foreground block text-xs font-bold tracking-wider uppercase">Service area</span>
            <span class="text-kom-charcoal block text-lg font-extrabold">{business.serviceArea}, MI</span>
          </span>
        </div>
        <p class="text-muted-foreground px-1 text-sm leading-relaxed">
          Property manager or investor? Open the property-management section in the form so we can
          set up the right plan for your portfolio.
        </p>
      </div>

      <form
        name="request-service"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="reveal border-border rounded-lg border bg-white p-6 shadow-card sm:p-8"
        style="--rd: 90ms"
      >
        <input type="hidden" name="form-name" value="request-service" />
        <input type="hidden" name="subject" value="New service request — kom.construction" />
        <p class="hidden" aria-hidden="true">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="space-y-1.5">
            <Label for="name">Name <span class="text-error">*</span></Label>
            <Input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="space-y-1.5">
            <Label for="phone">Phone <span class="text-error">*</span></Label>
            <Input type="tel" id="phone" name="phone" required autocomplete="tel" />
          </div>
          <div class="space-y-1.5">
            <Label for="email">Email <span class="text-error">*</span></Label>
            <Input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="space-y-1.5">
            <Label for="city">City <span class="text-error">*</span></Label>
            <Input type="text" id="city" name="city" required autocomplete="address-level2" placeholder="e.g. Warren" />
          </div>
          <div class="space-y-1.5 sm:col-span-2">
            <Label for="property-address">Property address <span class="text-muted-foreground font-normal">(optional)</span></Label>
            <Input type="text" id="property-address" name="property-address" autocomplete="street-address" />
          </div>
          <div class="space-y-1.5">
            <Label for="service">Service needed <span class="text-error">*</span></Label>
            <select id="service" name="service" required class={selectClass}>
              <option value="" disabled selected>Choose a service</option>
              {serviceOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
          </div>
          <div class="space-y-1.5">
            <Label for="urgency">How urgent is it? <span class="text-error">*</span></Label>
            <select id="urgency" name="urgency" required class={selectClass}>
              <option value="" disabled selected>Choose urgency</option>
              {urgencyOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
          </div>
          <div class="space-y-1.5 sm:col-span-2">
            <Label for="message">What's going on? <span class="text-muted-foreground font-normal">(optional)</span></Label>
            <Textarea
              id="message"
              name="message"
              rows={4}
              placeholder="Tell us about the job — what needs doing, roughly when, anything we should know."
            />
          </div>
          <fieldset class="sm:col-span-2">
            <legend class="text-sm font-bold">Preferred contact method</legend>
            <div class="mt-2 flex flex-wrap gap-x-6 gap-y-2">
              {
                ["Phone call", "Text", "Email"].map((method, index) => (
                  <label class="flex items-center gap-2 text-sm font-medium">
                    <input
                      type="radio"
                      name="preferred-contact"
                      value={method}
                      checked={index === 0}
                      class="text-primary focus:ring-primary border-input size-4"
                    />
                    {method}
                  </label>
                ))
              }
            </div>
          </fieldset>
        </div>

        <details class="border-border group mt-6 rounded-md border">
          <summary
            class="text-kom-charcoal flex cursor-pointer list-none items-center justify-between gap-2 rounded-md px-4 py-3 text-sm font-bold [&::-webkit-details-marker]:hidden"
          >
            Property manager, landlord, or investor? Add portfolio details
            <ChevronDown class="size-4.5 shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" />
          </summary>
          <div class="grid gap-5 border-t px-4 py-5 sm:grid-cols-2">
            <div class="space-y-1.5">
              <Label for="company">Company name</Label>
              <Input type="text" id="company" name="company" autocomplete="organization" />
            </div>
            <div class="space-y-1.5">
              <Label for="unit-count">Number of properties / units</Label>
              <Input type="text" id="unit-count" name="unit-count" inputmode="numeric" placeholder="e.g. 12 units" />
            </div>
            <fieldset class="sm:col-span-2">
              <legend class="text-sm font-bold">What kind of service?</legend>
              <div class="mt-2 flex flex-wrap gap-x-6 gap-y-2">
                {
                  ["One-time job", "Recurring service", "Not sure yet"].map((type) => (
                    <label class="flex items-center gap-2 text-sm font-medium">
                      <input
                        type="radio"
                        name="service-frequency"
                        value={type}
                        class="text-primary focus:ring-primary border-input size-4"
                      />
                      {type}
                    </label>
                  ))
                }
              </div>
            </fieldset>
          </div>
        </details>

        <Button type="submit" variant="primary" size="lg" class="mt-6 w-full font-bold">
          Send request
        </Button>
        <p class="text-muted-foreground mt-3 text-center text-xs">
          We only use your info to respond to this request. For lockouts, calling
          {business.phone} is fastest.
        </p>
      </form>
    </div>
  </div>
</section>
