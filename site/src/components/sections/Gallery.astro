---
import { Image } from "astro:assets";

import SectionHeader from "../common/SectionHeader.astro";

import kitchen from "../../assets/images/kitchen-remodel.jpg";
import bathroom from "../../assets/images/bathroom-remodel.jpg";
import homeExterior from "../../assets/images/home-exterior.jpg";
import painting from "../../assets/images/painting-drywall.jpg";
import renovation from "../../assets/images/interior-renovation.jpg";
import concrete from "../../assets/images/concrete-work.jpg";
import framing from "../../assets/images/construction-framing.jpg";

/**
 * Temporary stock photos, labeled below. Replace with real KOM USA project
 * photos (before/after pairs work well) as they're collected.
 */
const gallery = [
  { image: kitchen, label: "Kitchen remodeling", alt: "Remodeled kitchen with white cabinets and gas range (stock photo)" },
  { image: homeExterior, label: "Exterior maintenance", alt: "Well-kept two-story home with a wraparound porch (stock photo)" },
  { image: bathroom, label: "Bathroom remodeling", alt: "Renovated bathroom with glass shower and double vanity (stock photo)" },
  { image: renovation, label: "Interior renovation", alt: "Contractor finishing a ceiling during an interior renovation (stock photo)" },
  { image: painting, label: "Painting & drywall", alt: "Roller applying fresh paint to an interior wall (stock photo)" },
  { image: concrete, label: "Concrete & structural", alt: "Crew working with rebar on a concrete pour (stock photo)" },
  { image: framing, label: "New construction", alt: "Construction crew reviewing a framed build site (stock photo)" },
];
---

<section id="projects" class="section-pad scroll-mt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="Our Work"
      lead="The kind of projects we take on. Temporary stock photos shown for now — real KOM USA project photos are on the way."
    />
  </div>

  <div class="mx-auto mt-12 max-w-6xl px-4 sm:px-6">
    <ul
      class="reveal flex snap-x snap-mandatory gap-4 overflow-x-auto pb-3"
      style="scrollbar-width: thin"
    >
      {
        gallery.map((item) => (
          <li class="group relative w-72 shrink-0 snap-start overflow-hidden rounded-xl shadow-card">
            <Image
              src={item.image}
              alt={item.alt}
              class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
              widths={[480, 800]}
              sizes="288px"
              loading="lazy"
            />
            <p class="bg-kom-ink/85 absolute inset-x-0 bottom-0 px-4 py-2 text-sm font-bold text-white">
              {item.label}
              <span class="block text-xs font-medium text-white/70">Sample photo</span>
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
