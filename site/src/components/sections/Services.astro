---
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import Headset from "@tabler/icons/outline/headset.svg";

import Icon from "../common/Icon.astro";
import SectionHeader from "../common/SectionHeader.astro";
import { serviceCategories } from "../../data/business";

const cardCta: Record<string, { label: string; href: string }> = {
  "construction-remodeling": { label: "Request remodeling help", href: "/#request-service" },
  "property-maintenance": { label: "Request maintenance", href: "/#request-service" },
  locksmith: { label: "See upfront pricing", href: "/locksmith" },
  "chimney-care": { label: "Request chimney service", href: "/#request-service" },
  "property-management": { label: "Request portfolio service", href: "/#request-service" },
};

const maxJobs = 5;
---

<section id="services" class="section-pad scroll-mt-16 bg-kom-cream pt-0">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="Professional help across five trades"
      lead="From a $25 key copy to a full home addition — one local crew handles it."
    />

    <ul class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        serviceCategories.map((category, index) => {
          const cta = cardCta[category.id];
          const jobs = category.items.slice(0, maxJobs);
          return (
            <li
              id={category.id}
              class="reveal border-border flex scroll-mt-24 flex-col rounded-xl border bg-white p-6 shadow-card transition-shadow hover:shadow-card-hover"
              style={`--rd: ${(index % 3) * 70}ms`}
            >
              <span class="bg-kom-sage-tint text-kom-field flex size-13 items-center justify-center rounded-lg">
                <Icon name={category.icon} class="size-7" />
              </span>
              <h3 class="text-kom-ink mt-5 text-xl font-bold">{category.title}</h3>
              <p class="text-muted-foreground mt-1.5 text-sm leading-relaxed">{category.blurb}</p>
              <p class="text-kom-charcoal/80 mt-3 flex-1 text-sm leading-relaxed">
                {jobs.join(" · ")}
                {category.items.length > maxJobs && " · and more"}
              </p>
              <a
                href={cta.href}
                class="text-kom-field hover:text-kom-field-hover mt-4 inline-flex items-center gap-1.5 rounded-sm text-sm font-bold transition-colors focus-visible:ring-3 focus-visible:ring-kom-field/50 focus-visible:outline-none"
              >
                {cta.label}
                <ArrowRight class="size-4" aria-hidden="true" />
              </a>
            </li>
          );
        })
      }

      <li class="reveal bg-kom-field-deep flex flex-col rounded-xl p-6 text-white" style="--rd: 350ms">
        <span class="flex size-13 items-center justify-center rounded-lg bg-white/15">
          <Headset class="size-7" aria-hidden="true" />
        </span>
        <h3 class="mt-5 text-xl font-bold">Not sure who to call?</h3>
        <p class="mt-1.5 flex-1 text-sm leading-relaxed text-white/75">
          If it's on your property and on your list, ask us. If we can't do it, we'll say so —
          no runaround.
        </p>
        <a
          href="/#request-service"
          class="text-kom-tan mt-4 inline-flex items-center gap-1.5 rounded-sm text-sm font-bold transition-colors hover:text-white focus-visible:ring-3 focus-visible:ring-white/40 focus-visible:outline-none"
        >
          Ask about your project
          <ArrowRight class="size-4" aria-hidden="true" />
        </a>
      </li>
    </ul>
  </div>
</section>
