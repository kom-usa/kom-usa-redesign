---
import { Image } from "astro:assets";
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";

import SectionHeader from "../common/SectionHeader.astro";
import { serviceCategories } from "../../data/business";

import kitchenRemodel from "../../assets/images/kitchen-remodel.jpg";
import homeExterior from "../../assets/images/home-exterior.jpg";
import doorLock from "../../assets/images/door-lock.jpg";
import fireplaceChimney from "../../assets/images/fireplace-chimney.jpg";
import apartmentBuilding from "../../assets/images/apartment-building.jpg";

/** Card photos are temporary stock images until real project photos exist. */
const cardImages: Record<string, { image: ImageMetadata; alt: string }> = {
  "construction-remodeling": {
    image: kitchenRemodel,
    alt: "Remodeled kitchen with white cabinets (stock photo)",
  },
  "property-maintenance": {
    image: homeExterior,
    alt: "Well-kept two-story home with a wraparound porch (stock photo)",
  },
  locksmith: {
    image: doorLock,
    alt: "Smart lock installed on a unit door (stock photo)",
  },
  "chimney-care": {
    image: fireplaceChimney,
    alt: "Fire burning in a brick fireplace (stock photo)",
  },
  "property-management": {
    image: apartmentBuilding,
    alt: "Apartment building with balconies (stock photo)",
  },
};

const centerIndex = 2; // Locksmith card is raised, matching the mockup
---

<section id="services" class="section-pad scroll-mt-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeader
      title="Our Services"
      lead="Five trades, one local crew — from a $25 key copy to a full home addition."
    />

    <ul class="mt-12 grid gap-5 min-[480px]:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
      {
        serviceCategories.map((category, index) => (
          <li
            class:list={[
              "reveal group relative h-72 overflow-hidden rounded-xl shadow-card transition-transform duration-200",
              index === centerIndex && "lg:z-10 lg:scale-105 lg:shadow-card-hover",
            ]}
            style={`--rd: ${index * 70}ms`}
          >
            <a
              href={`#${category.id}`}
              class="block h-full focus-visible:ring-3 focus-visible:ring-kom-field focus-visible:outline-none"
            >
              <Image
                src={cardImages[category.id].image}
                alt={cardImages[category.id].alt}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.04] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
                widths={[480, 800]}
                sizes="(min-width: 1024px) 20vw, (min-width: 480px) 50vw, 100vw"
                loading="lazy"
              />
              <span
                class="absolute inset-0 bg-gradient-to-t from-kom-ink/85 via-kom-ink/25 to-transparent"
                aria-hidden="true"
              />
              <span class="absolute inset-x-0 bottom-0 p-4">
                <span class="font-serif block text-xl leading-tight font-bold text-white">
                  {category.title}
                </span>
                <span class="mt-1.5 inline-flex items-center gap-1 text-xs font-bold text-white/80 transition-colors group-hover:text-white">
                  View details
                  <ArrowRight class="size-3.5" aria-hidden="true" />
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <dl class="reveal border-border mt-10 divide-y divide-border rounded-xl border bg-white px-6 shadow-card">
      {
        serviceCategories.map((category) => (
          <div id={category.id} class="scroll-mt-24 gap-x-6 py-4 sm:grid sm:grid-cols-[220px_1fr]">
            <dt class="text-kom-ink text-sm font-bold">{category.title}</dt>
            <dd class="text-muted-foreground mt-1 text-sm leading-relaxed sm:mt-0">
              {category.items.join(" · ")}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
