# Sanity — copy this file to .env and fill in real values. Never commit .env.
#   SANITY_PROJECT_ID      = the Sanity project id (sanity.io/manage → project → Project ID).
#                            Not secret. Also set in Netlify env.
#   SANITY_DATASET         = dataset name, e.g. "production". Set the dataset to PUBLIC read
#                            so builds need no token. Also set in Netlify env.
#   SANITY_API_VERSION     = pinned API date, e.g. 2024-10-01.
#   SANITY_API_READ_TOKEN  = ONLY needed if the dataset is PRIVATE. If so, also add to Netlify env.
#   SANITY_API_WRITE_TOKEN = LOCAL ONLY — used by scripts/sanity-seed.mjs to write seed content.
#                            Never goes to Netlify.

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
