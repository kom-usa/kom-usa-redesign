# Storyblok — copy this file to .env and fill in real values. Never commit .env.
# Which token is which:
#   STORYBLOK_TOKEN            = the space's "Preview" access token
#                                (Storyblok → your space → Settings → Access tokens).
#                                Used by the site to fetch content. Also goes into Netlify env.
#   STORYBLOK_MANAGEMENT_TOKEN = your Personal access token
#                                (Storyblok → account menu (top right) → Account settings →
#                                Personal access tokens). Used ONLY by local setup/seed
#                                scripts. Never goes to Netlify.
#   STORYBLOK_SPACE_ID         = the number in your space's URL:
#                                app.storyblok.com/#/me/spaces/<THIS NUMBER>/...

STORYBLOK_TOKEN=
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_SPACE_ID=

# STORYBLOK_PREVIEW = set to true only for the SSR preview deployment/local
#                     preview test. Leave unset for the normal static build.
STORYBLOK_PREVIEW=

# PREVIEW_ACCESS_KEY = shared secret gating the SSR preview build (STORYBLOK_PREVIEW=true).
#                      Required to view draft content via ?_preview=<key> outside the
#                      Storyblok visual editor. Set your own value here for local preview
#                      testing, and set the same value in Netlify's Branch deploys context
#                      (Site settings → Environment variables) for the `preview` branch.
#                      Not needed for the production (static) build.
PREVIEW_ACCESS_KEY=
