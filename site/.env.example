# Sanity — copy this file to .env and fill in real values. Never commit .env.
#   SANITY_PROJECT_ID      = the Sanity project id (sanity.io/manage → project → Project ID).
#                            Not secret. Also set in Netlify env.
#   SANITY_DATASET         = dataset name, e.g. "production". Set the dataset to PUBLIC read
#                            so builds need no token. Also set in Netlify env.
#   SANITY_API_VERSION     = pinned API date, e.g. 2024-10-01.
#   SANITY_API_READ_TOKEN  = ONLY needed if the dataset is PRIVATE. If so, also add to Netlify env.
#   SANITY_API_WRITE_TOKEN = LOCAL ONLY — used by scripts/sanity-seed.mjs to write seed content.
#                            Never goes to Netlify.

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Brevo — Netlify Forms → Brevo contact sync + customer acknowledgement email.
# Triggered by netlify/functions/form-brevo.mts on verified form submissions.
#   BREVO_API_KEY       = Brevo v3 API key (SMTP & API → Generate a new API key).
#                         Required in Netlify production env. Never commit.
#   BREVO_LIST_ID       = Optional numeric list ID for "Website leads" contacts.
#   BREVO_SENDER_EMAIL  = Verified sender in Brevo (default: contact@kom-usa.com).
#   BREVO_SENDER_NAME   = Display name on acknowledgement emails (default: KOM USA).
#
# One-time local setup (creates custom contact attributes):
#   node scripts/brevo-setup.mjs
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Google Maps / Places — service-area map embed + live review counter.
#   GOOGLE_MAPS_API_KEY   = key with "Places API (New)" + "Maps Embed API" enabled.
#                           Used at build time (review numbers baked into the page),
#                           by netlify/functions/google-reviews.mts (live counter),
#                           and in the map iframe. Set in Netlify env AND here.
#   GOOGLE_MAPS_EMBED_KEY = OPTIONAL second key used only for the public map iframe.
#                           If you restrict keys, make this one referrer-restricted to
#                           kom-usa.com (Embed API only) and keep GOOGLE_MAPS_API_KEY
#                           server-side (Places API only, no referrer restriction —
#                           referrer-restricted keys fail for server/build calls).
#   GOOGLE_MAPS_PLACE_ID  = OPTIONAL but recommended. The stable Google place ID
#                           for KOM USA; when omitted, the server uses a tightly
#                           scoped Metro Detroit Text Search fallback.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_EMBED_KEY=
GOOGLE_MAPS_PLACE_ID=
